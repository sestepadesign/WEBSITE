---
import { ui } from '../data/translations';

interface Props {
  lang: 'en' | 'es' | 'de';
}

const { lang } = Astro.props;

const t = (key: keyof typeof ui[typeof lang]) => {
  return ui[lang][key] || key;
};

const currentYear = new Date().getFullYear();

const whatsappTexts = {
  en: "Hello S'Estepa Design! I visited your website and would like to request a consultation.",
  es: "Hola S'Estepa Design! He visitado su web y me gustaría solicitar una consulta.",
  de: "Hallo S'Estepa Design! Ich habe Ihre Website besucht und möchte eine Beratung anfragen."
};
const whatsappUrl = `https://wa.me/34681272252?text=${encodeURIComponent(whatsappTexts[lang])}`;
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href={`/${lang}/`} class="footer-logo" aria-label="S'Estepa Design">
          <img src="/images/logo.png" alt="S'Estepa Design Logo" class="footer-logo-img" />
        </a>
        <p class="footer-tagline">{t('footer.description')}</p>
      </div>
      
      <div class="footer-info">
        <h4 class="footer-heading">Studio</h4>
        <p class="footer-text">Mallorca, Balearic Islands</p>
        <p class="footer-text"><a href="mailto:sofia@sestepa.com" class="footer-email">sofia@sestepa.com</a></p>
        <p class="footer-text">
          <a href={whatsappUrl} class="footer-whatsapp" target="_blank" rel="noopener noreferrer">
            +34 681 272 252
          </a>
        </p>
      </div>

      <div class="footer-links-col">
        <h4 class="footer-heading">Menu</h4>
        <ul class="footer-links">
          <li><a href={`/${lang}/`}>{t('nav.home')}</a></li>
          <li><a href={`/${lang}/about/`}>{t('nav.about')}</a></li>
          <li><a href={`/${lang}/portfolio/`}>{t('nav.portfolio')}</a></li>
          <li><a href={`/${lang}/press/`}>{t('nav.press')}</a></li>
          <li><a href={`/${lang}/contact/`}>{t('nav.contact')}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-info">
        <p class="copyright">&copy; {currentYear} S'Estepa Design. All rights reserved.</p>
        <div class="footer-legal-links">
          <a href={`/${lang}/legal-notice/`}>{t('footer.legal')}</a>
          <span class="separator">•</span>
          <a href={`/${lang}/privacy-policy/`}>{t('footer.privacy')}</a>
          <span class="separator">•</span>
          <a href={`/${lang}/cookies/`}>{t('footer.cookies')}</a>
        </div>
      </div>
      <p class="credit">
        Mediterranean Elegance
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-sand-base);
    border-top: 1px solid var(--color-sand-dark);
    padding: 6rem 0 3rem 0;
    margin-top: auto;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--color-sand-dark);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
  }

  .footer-logo-img {
    width: 280px;
    height: auto;
    max-width: 100%;
    object-fit: contain;
    transition: var(--transition-fast);
  }

  .footer-logo-img:hover {
    opacity: 0.8;
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--color-charcoal-light);
    max-width: 320px;
    line-height: 1.6;
  }

  .footer-heading {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-olive-dark);
    margin-bottom: 1.5rem;
  }

  .footer-text {
    font-size: 0.85rem;
    color: var(--color-charcoal-light);
    margin-bottom: 0.5rem;
  }

  .footer-email {
    color: var(--color-olive);
    transition: var(--transition-fast);
  }

  .footer-email:hover {
    color: var(--color-olive-dark);
  }

  .footer-whatsapp {
    color: var(--color-olive);
    font-weight: 500;
    transition: var(--transition-fast);
  }

  .footer-whatsapp:hover {
    color: var(--color-olive-dark);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--color-charcoal-light);
    transition: var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-olive);
    padding-left: 4px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    font-size: 0.75rem;
    color: var(--color-limestone);
    letter-spacing: 0.05em;
  }

  .footer-bottom-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-legal-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-legal-links a {
    color: var(--color-charcoal-light);
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .footer-legal-links a:hover {
    color: var(--color-olive);
  }

  .separator {
    color: var(--color-sand-dark);
    font-size: 0.6rem;
  }

  .credit {
    font-style: italic;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 4rem 0 2rem 0;
    }

    .footer-top {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
    }

    .footer-legal-links {
      flex-wrap: wrap;
      gap: 0.5rem 0.75rem;
    }
  }
</style>
