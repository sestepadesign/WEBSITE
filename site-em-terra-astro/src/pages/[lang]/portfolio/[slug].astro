---
import Layout from '../../../layouts/Layout.astro';
import { ui } from '../../../data/translations';
import { projects } from '../../../data/projects';

export function getStaticPaths() {
  const paths = [];
  const langs = ['en', 'es', 'de'] as const;
  
  for (const lang of langs) {
    for (const project of projects) {
      paths.push({
        params: { lang, slug: project.slug },
        props: { project }
      });
    }
  }
  return paths;
}

const { project } = Astro.props;
const { lang } = Astro.params as { lang: 'en' | 'es' | 'de' };

const projectCategoryMap: Record<string, 'mediterranean' | 'romantic' | 'tropical' | 'dry'> = {
  'binissalem': 'mediterranean',
  'bunyola': 'mediterranean',
  'campanet-garden': 'romantic',
  'finca-garden-campos-mallorca': 'romantic',
  'costadelacalma': 'tropical',
  'crestatx-garden-design': 'dry',
  'hotelcabotlasvelas': 'dry',
  'garden-design-llubi-mallorca': 'romantic',
  'sant-llorenc': 'mediterranean',
  'terrace-garden-santa-eugenia': 'tropical',
  'santa-ponsa': 'dry',
  'son-vida': 'mediterranean',
  'terrace-garden-in-palma': 'tropical',
  'vertical-gardens-in-mallorca': 'tropical'
};

const categorySlug = projectCategoryMap[project.slug] || 'mediterranean';

const t = (key: keyof typeof ui[typeof lang]) => {
  return ui[lang][key] || key;
};

const translation = project[lang];
const pageTitle = `${translation.title} | S'Estepa Design`;
const pageDescription = translation.description[0] || "";
---

<Layout 
  title={pageTitle} 
  description={pageDescription} 
  lang={lang}
  image={project.ogImage ?? project.cover}
>
  <article class="project-detail-page">
    <!-- Main cover — full width directly below site header -->
    <div class="project-cover-hero">
      <img
        src={project.cover}
        alt={translation.title}
        class="project-cover-img"
        fetchpriority="high"
      />
    </div>

    <div class="container section-padding">
      <!-- Back Link -->
      <a href={`/${lang}/portfolio/`} class="back-link">
        &larr; {t('project.back')}
      </a>

      <!-- Main Header -->
      <header class="project-header">
        <a href={`/${lang}/portfolio/?filter=${categorySlug}`} class="project-category-tag-link">
          <span class="project-category-tag">{translation.category}</span>
        </a>
        <h1 class="project-title">{translation.title}</h1>
        <p class="project-subtitle">{translation.subtitle}</p>
      </header>

      <!-- Project Metadata & Content Grid -->
      <div class="project-grid">
        <!-- Text Content -->
        <div class="project-description">
          {translation.description.map(paragraph => (
            <p>{paragraph}</p>
          ))}
        </div>

        <!-- Specifications Panel -->
        <div class="project-meta-panel">
          <h3 class="meta-heading">{t('project.details')}</h3>
          
          <div class="meta-item">
            <span class="meta-label">{t('project.location')}</span>
            <span class="meta-value">{project.location}</span>
          </div>

          <div class="meta-item">
            <span class="meta-label">{t('project.category')}</span>
            <a href={`/${lang}/portfolio/?filter=${categorySlug}`} class="meta-value-link">
              <span class="meta-value">{translation.category}</span>
            </a>
          </div>

          <div class="meta-item">
            <span class="meta-label">{t('project.year')}</span>
            <span class="meta-value">{project.year}</span>
          </div>

          {project.architect && (
            <div class="meta-item">
              <span class="meta-label">{t('project.architect')}</span>
              <span class="meta-value">{project.architect}</span>
            </div>
          )}

          {translation.botanical && (
            <div class="meta-item botanical-item">
              <span class="meta-label">{t('project.botanical')}</span>
              <span class="meta-value botanical-value">{translation.botanical}</span>
            </div>
          )}
        </div>
      </div>

      <!-- Video Section (If present) -->
      {project.video && (
        <section class="project-video-section">
          <h2 class="section-heading">
            {lang === 'en' && "Garden Experience"}
            {lang === 'es' && "Experiencia del Jardín"}
            {lang === 'de' && "Gartenerlebnis"}
          </h2>
          <div class="video-aspect-ratio">
            <iframe 
              src={project.video} 
              title={`${translation.title} video`}
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              allowfullscreen
            ></iframe>
          </div>
        </section>
      )}

      <!-- Image Gallery Grid -->
      {project.images.length > 0 && (
        <section class="project-gallery">
          <h2 class="section-heading">
            {lang === 'en' && "Visual Record"}
            {lang === 'es' && "Registro Visual"}
            {lang === 'de' && "Visuelles Protokoll"}
          </h2>
          <div class="gallery-grid">
            {project.images.map((img, idx) => (
              <button 
                class="gallery-item-btn" 
                data-src={`/portfolio/${project.slug}/images/${img}`} 
                data-index={idx}
                aria-label={`View image ${idx + 1} in fullscreen`}
              >
                <div class="gallery-item">
                  <img 
                    src={`/portfolio/${project.slug}/images/${img}`} 
                    alt={`${translation.title} detail ${idx + 1}`}
                    loading="lazy"
                    class="gallery-img"
                  />
                </div>
              </button>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>

  <!-- Lightbox Modal -->
  <div class="lightbox" id="lightboxModal" aria-hidden="true" role="dialog">
    <div class="lightbox-overlay" id="lightboxOverlay"></div>
    <div class="lightbox-content">
      <button class="lightbox-close" id="lightboxClose" aria-label="Close image">&times;</button>
      <button class="lightbox-arrow lightbox-prev" id="lightboxPrev" aria-label="Previous image">&larr;</button>
      <img src="" alt="" class="lightbox-img" id="lightboxImg" />
      <button class="lightbox-arrow lightbox-next" id="lightboxNext" aria-label="Next image">&rarr;</button>
      <span class="lightbox-caption" id="lightboxCaption"></span>
    </div>
  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll('.gallery-item-btn') as NodeListOf<HTMLButtonElement>;
  const lightbox = document.getElementById('lightboxModal');
  const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
  const lightboxCaption = document.getElementById('lightboxCaption');
  const lightboxClose = document.getElementById('lightboxClose');
  const lightboxOverlay = document.getElementById('lightboxOverlay');
  const lightboxPrev = document.getElementById('lightboxPrev');
  const lightboxNext = document.getElementById('lightboxNext');

  if (lightbox && lightboxImg && lightboxCaption && lightboxClose && lightboxOverlay && lightboxPrev && lightboxNext) {
    const images: { src: string; caption: string }[] = [];
    buttons.forEach((btn) => {
      const src = btn.getAttribute('data-src') || '';
      const img = btn.querySelector('img');
      const alt = img ? img.getAttribute('alt') || '' : '';
      images.push({ src, caption: alt });
    });

    let currentIndex = 0;

    const openLightbox = (index: number) => {
      currentIndex = index;
      updateLightbox();
      lightbox.classList.add('active');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      lightbox.classList.remove('active');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lightboxImg.src = '';
    };

    const updateLightbox = () => {
      const current = images[currentIndex];
      if (current) {
        lightboxImg.src = current.src;
        lightboxImg.alt = current.caption;
        lightboxCaption.textContent = `${currentIndex + 1} / ${images.length}`;
      }
    };

    const showPrev = () => {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      updateLightbox();
    };

    const showNext = () => {
      currentIndex = (currentIndex + 1) % images.length;
      updateLightbox();
    };

    buttons.forEach((btn, index) => {
      btn.addEventListener('click', () => {
        openLightbox(index);
      });
    });

    lightboxClose.addEventListener('click', closeLightbox);
    lightboxOverlay.addEventListener('click', closeLightbox);
    
    lightboxPrev.addEventListener('click', (e) => {
      e.stopPropagation();
      showPrev();
    });
    
    lightboxNext.addEventListener('click', (e) => {
      e.stopPropagation();
      showNext();
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('active')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') showPrev();
        if (e.key === 'ArrowRight') showNext();
      }
    });

    // Swipe controls for mobile touchscreen
    let touchStartX = 0;
    let touchEndX = 0;

    lightbox.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    lightbox.addEventListener('touchend', (e: TouchEvent) => {
      touchEndX = e.changedTouches[0].screenX;
      const swipeThreshold = 50;
      if (touchEndX < touchStartX - swipeThreshold) {
        showNext();
      }
      if (touchEndX > touchStartX + swipeThreshold) {
        showPrev();
      }
    }, { passive: true });
  }
</script>

<style>
  .project-detail-page {
    background-color: var(--color-sand-light);
  }

  .section-padding {
    padding-top: 4rem;
  }

  .project-cover-hero {
    width: 100%;
    margin-top: 5.5rem;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    background-color: var(--color-sand-base);
  }

  .project-cover-hero .project-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .back-link {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-olive);
    display: inline-block;
    margin-bottom: 3rem;
    transition: var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-olive-dark);
    transform: translateX(-4px);
  }

  .project-header {
    margin-bottom: 4rem;
    max-width: 900px;
  }

  .project-category-tag-link {
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .project-category-tag {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-olive);
    font-weight: 500;
    display: block;
    transition: color var(--transition-fast);
  }

  .project-category-tag-link:hover .project-category-tag {
    color: var(--color-olive-dark);
  }

  .project-title {
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 1.1;
    font-weight: 300;
    color: var(--color-charcoal);
    margin-bottom: 1.5rem;
  }

  .project-subtitle {
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-charcoal-light);
    line-height: 1.6;
  }

  /* Grid details layout */
  .project-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 6rem;
    align-items: start;
    margin-bottom: 6rem;
  }

  .project-description {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project-description p {
    font-size: 1.15rem;
    color: var(--color-charcoal-light);
    line-height: 1.8;
  }

  .project-meta-panel {
    background-color: var(--color-sand-base);
    padding: 3rem;
    border: 1px solid var(--color-sand-dark);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .meta-heading {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--color-sand-dark);
    padding-bottom: 0.75rem;
    text-transform: uppercase;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    font-weight: 500;
    color: var(--color-olive-dark);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-limestone);
    font-weight: 500;
  }

  .meta-value-link {
    text-decoration: none;
    display: inline-block;
  }

  .meta-value {
    font-size: 0.95rem;
    color: var(--color-charcoal);
    transition: color var(--transition-fast);
  }

  .meta-value-link:hover .meta-value {
    color: var(--color-olive);
  }

  .botanical-value {
    font-style: italic;
  }

  /* Video style */
  .project-video-section {
    margin-bottom: 6rem;
    border-top: 1px solid var(--color-sand-dark);
    padding-top: 5rem;
  }

  .section-heading {
    font-size: 2rem;
    font-weight: 300;
    margin-bottom: 3rem;
  }

  .video-aspect-ratio {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
    background-color: var(--color-sand-base);
  }

  .video-aspect-ratio iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Gallery style */
  .project-gallery {
    border-top: 1px solid var(--color-sand-dark);
    padding-top: 5rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }

  .gallery-item {
    overflow: hidden;
    background-color: var(--color-sand-base);
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .gallery-item:hover .gallery-img {
    transform: scale(1.04);
  }

  @media (max-width: 992px) {
    .project-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .project-cover-hero {
      margin-top: 4.5rem;
      aspect-ratio: 4 / 3;
    }

    .section-padding {
      padding-top: 2.5rem;
    }

    .project-header {
      margin-bottom: 2.5rem;
    }

    .project-meta-panel {
      padding: 2rem;
    }
  }

  /* Lightbox Modal CSS */
  .gallery-item-btn {
    display: block;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
  }

  .lightbox {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 2000;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .lightbox.active {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(31, 33, 31, 0.95);
    backdrop-filter: blur(5px);
  }

  .lightbox-content {
    position: relative;
    z-index: 2010;
    max-width: 90%;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 75vh;
    object-fit: contain;
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
  }

  .lightbox-caption {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-sand-light);
    letter-spacing: 0.05em;
  }

  .lightbox-close {
    position: absolute;
    top: -3.5rem;
    right: 0;
    background: none;
    border: none;
    color: var(--color-white);
    font-size: 3rem;
    cursor: pointer;
    line-height: 1;
    transition: opacity 0.2s ease;
  }

  .lightbox-close:hover {
    opacity: 0.7;
  }

  .lightbox-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(31, 33, 31, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: var(--color-white);
    font-size: 1.5rem;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    z-index: 2020;
  }

  .lightbox-arrow:hover {
    background: rgba(255, 255, 255, 0.9);
    color: var(--color-charcoal);
    border-color: var(--color-white);
  }

  .lightbox-prev {
    left: -6rem;
  }

  .lightbox-next {
    right: -6rem;
  }

  @media (max-width: 1200px) {
    .lightbox-prev {
      left: 1rem;
    }
    .lightbox-next {
      right: 1rem;
    }
    .lightbox-arrow {
      width: 3rem;
      height: 3rem;
      font-size: 1.25rem;
    }
  }
</style>
