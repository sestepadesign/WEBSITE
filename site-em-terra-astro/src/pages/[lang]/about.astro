---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../data/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params as { lang: 'en' | 'es' | 'de' };

const t = (key: keyof typeof ui[typeof lang]) => {
  return ui[lang][key] || key;
};

const descriptions = {
  en: "Meet the S'Estepa Design team led by Pedro Campaner. We are a specialized team of landscape architects, botanists, and execution experts in Mallorca.",
  es: "Conozca al equipo de S'Estepa Design liderado por Pedro Campaner. Un equipo especializado de paisajistas, botánicos y expertos en Mallorca.",
  de: "Lernen Sie das Team von S'Estepa Design unter der Leitung von Pedro Campaner kennen. Landschaftsarchitekten, Botaniker und Bauspezialisten auf Mallorca."
};

const pageDescription = descriptions[lang];

const ethosTitle = {
  en: "Crafting living landscapes that mirror the soul of Mallorca",
  es: "Moldeando paisajes vivos que reflejan el alma de Mallorca",
  de: "Lebendige Landschaften gestalten, die die Seele Mallorcas widerspiegeln"
};

const ethosMainText = {
  en: "S'Estepa is a dedicated landscape design studio crafting bespoke town gardens, expansive country estates, and hidden urban terraces. Deeply rooted in the Balearic soil, our practice merges botanical expertise with architectural precision.",
  es: "S'Estepa es un estudio de diseño paisajístico dedicado a la creación de jardines a medida en casas de pueblo, grandes fincas de campo y terrazas urbanas. Con un profundo arraigo en la tierra balear, nuestra práctica fusiona el conocimiento botánico con la precisión arquitectónica.",
  de: "S'Estepa ist ein engagiertes Atelier für Landschaftsgestaltung, das maßgeschneiderte Stadthausgärten, weitläufige Landgüter und verborgene urbane Terrassen entwirft. Tief in der balearischen Erde verwurzelt, verbindet unsere Arbeit botanisches Fachwissen mit architektonischer Präzision."
};

const ethosSubText = {
  en: "Under the direction of Pedro Campaner, we coordinate every stage from initial design concept to mature soil management, technical irrigation, and stone construction. We do not just build gardens; we foster living ecosystems that grow gracefully over time.",
  es: "Bajo la dirección de Pedro Campaner, coordinamos cada etapa, desde el concepto inicial hasta la preparación de la tierra, el riego técnico y la cantería tradicional. No solo creamos jardines; cultivamos ecosistemas vivos que maduran con gracia a lo largo del tiempo.",
  de: "Unter der Leitung von Pedro Campaner begleiten wir jede Phase – vom ersten Entwurf über die Bodenpflege und technische Bewässerung bis hin zum traditionellen Steinbau. Wir bauen nicht nur Gärten; wir kultivieren lebendige Ökosysteme, die im Laufe der Jahre an Anmut gewinnen."
};

const teamSectionTitle = {
  en: "Landscape Specialists",
  es: "Especialistas en Paisajismo",
  de: "Landschaftsspezialisten"
};

const teamSectionSubtitle = {
  en: "An integrated collective of landscape designers, botanists, and master builders bringing 27 years of local expertise to Mallorca’s finest estates.",
  es: "Un colectivo integrado de diseñadores paisajistas, botánicos y maestros de obra que aporta 27 años de experiencia local a las fincas más distinguidas de Mallorca.",
  de: "Ein eingespieltes Kollektiv aus Landschaftsgestaltern, Botanikern und Baumeistern, das 27 Jahre lokale Erfahrung in die anspruchsvollsten Anwesen Mallorcas einbringt."
};

const team = [
  {
    name: "Pedro Campaner",
    role: {
      en: "AGRICULTURAL TECHNICIAN & LANDSCAPER",
      es: "TÉCNICO AGRÍCOLA Y PAISAJISTA",
      de: "LANDWIRTSCHAFTLICHER TECHNIKER & LANDSCHAFTSGESTALTER"
    },
    image: "/images/about/pedro.jpg",
    bio: {
      en: "Born and raised in Mallorca, Pedro is the founder of S’Estepa Design and S’Estepa Jardinería Integral. He is a technician in Agricultural Exploitations and specialised in Landscaping. With over 26 years of experience working and designing gardens in Mallorca, Ibiza, and Menorca, he envisions gardening as an extension of the Majorcan landscape, and his unique expertise is reflected in every design he creates. From aesthetic beauty to the perfect adaptation of the garden to its surroundings, Pedro considers sustainability a crucial factor. He takes into account water resources, climate, and terrain characteristics to achieve complete success in every project.",
      es: "Nacido y criado en Mallorca, Pedro es el fundador de S’Estepa Design y S’Estepa Jardinería Integral. Es técnico en Explotaciones Agrícolas y especialista en Paisajismo. Con más de 26 años de experiencia trabajando y diseñando jardines en Mallorca, Ibiza y Menorca, concibe la jardinería como una extensión del paisaje mallorquín, reflejando su experiencia única en cada diseño. Desde la belleza estética hasta la perfecta adaptación del jardín a su entorno, Pedro considera la sostenibilidad como un factor crucial, optimizando los recursos hídricos, el clima y el terreno para asegurar el éxito de cada proyecto.",
      de: "Auf Mallorca geboren und aufgewachsen, ist Pedro der Gründer von S'Estepa Design und S'Estepa Jardinería Integral. Er ist Techniker für landwirtschaftliche Betriebe und auf Landschaftsgestaltung spezialisiert. Mit über 26 Jahren Erfahrung in der Gestaltung von Gärten auf Mallorca, Ibiza und Menorca sieht er die Gartenarbeit als eine Erweiterung der mallorquinischen Landschaft an. Seine einzigartige Expertise spiegelt sich in jedem seiner Entwürfe wider. Von der ästhetischen Schönheit bis zur perfekten Anpassung an die Umgebung ist Nachhaltigkeit für Pedro ein entscheidender Faktor, bei dem er Wasserressourcen, Klima und Bodenbeschaffenheit stets einbezieht."
    }
  },
  {
    name: "Blanca Gonzalez",
    role: {
      en: "ADMINISTRATOR",
      es: "ADMINISTRADORA",
      de: "VERWALTUNG & FINANZEN"
    },
    image: "/images/about/blanca.jpg",
    bio: {
      en: "Blanca plays a crucial role as an internal administrative and accounting staff member for over six years. Her dedication focuses on ensuring that the economy of our garden projects is fair, equitable, and viable while guaranteeing the quality and value of each project. Blanca understands the importance of maintaining a fair and equitable economy, ensuring that expenses align with the expected value derived from each project. This allows our clients to achieve high-quality results without compromising their financial viability.",
      es: "Blanca desempeña un papel crucial en la administración interna y contabilidad desde hace más de seis años. Su dedicación se centra en asegurar que la economía de nuestros proyectos de jardines sea justa, equilibrada y viable, garantizando al mismo tiempo la calidad y el valor de cada obra. Blanca comprende la importancia de mantener una economía equilibrada, asegurando que cada inversión se traduzca en un resultado de alta gama y alta calidad sin comprometer la viabilidad financiera.",
      de: "Blanca spielt seit über sechs Jahren eine entscheidende Rolle in der internen Verwaltung und Buchhaltung. Ihr Engagement konzentriert sich darauf, sicherzustellen, dass die Wirtschaftlichkeit unserer Gartenprojekte fair, ausgewogen und tragfähig ist, während gleichzeitig die Qualität und der Wert jedes Projekts gewährleistet werden. Sie sorgt dafür, dass die Ausgaben mit dem erwarteten Wert übereinstimmen, was es unseren Kunden ermöglicht, erstklassige Ergebnisse ohne finanzielle Risiken zu erzielen."
    }
  },
  {
    name: "Sofia Grimaux",
    role: {
      en: "PROJECT MANAGER",
      es: "GESTORA DE PROYECTOS",
      de: "PROJEKTMANAGERIN"
    },
    image: "/images/about/sofia.jpg",
    bio: {
      en: "At S’Estepa Design, Sofia acts as the bridge between ideas and their realization in the garden. Her role combines rigorous management with creative sensitivity: she organizes teams, coordinates budgets and schedules, while maintaining close contact with each client to ensure they feel supported throughout the entire process. Her international outlook and fluency in several languages allow for clear and natural communication with clients from diverse cultural backgrounds, fostering trust and mutual understanding. With the ability to anticipate needs, solve unforeseen challenges, and preserve the aesthetic coherence of each project, Sofia ensures that working with S’Estepa Design is as smooth as it is rewarding. Her commitment is to transform visions into gardens that exceed expectations and endure over time.",
      es: "En S’Estepa Design, Sofia actúa como puente entre las ideas y su plasmación en el jardín. Su función combina una gestión rigurosa con sensibilidad creativa: organiza equipos, coordina presupuestos y plazos, manteniendo un contacto estrecho con cada cliente para que se sienta acompañado en todo momento. Su perfil internacional y dominio de varios idiomas permiten una comunicación fluida y natural con clientes de diversas nacionalidades, generando confianza y entendimiento mutuo. Con la capacidad de anticipar necesidades, resolver imprevistos y preservar la coherencia estética de cada obra, Sofia logra que trabajar con S’Estepa Design sea una experiencia tan fluida como gratificante.",
      de: "Bei S'Estepa Design fungiert Sofia als Brücke zwischen den Ideen und ihrer Realisierung im Garten. Ihre Rolle verbindet präzises Management mit kreativer Sensibilität: Sie organisiert Teams, koordiniert Budgets und Zeitpläne und hält engen Kontakt zu jedem Kunden, um eine kontinuierliche Unterstützung zu gewährleisten. Ihre internationale Ausrichtung und Fließendheit in mehreren Sprachen ermöglichen eine klare und natürliche Kommunikation mit Kunden unterschiedlicher Herkunft, was Vertrauen und gegenseitiges Verständnis fördert. Durch ihre Fähigkeit, Bedürfnisse vorherzusehen und die ästhetische Kohärenz jedes Projekts zu wahren, macht Sofia die Zusammenarbeit mit uns zu einer reibungslosen und lohnenden Erfahrung."
    }
  },
  {
    name: "Iulia Oleg Miron",
    role: {
      en: "ARCHITECT",
      es: "ARQUITECTA",
      de: "ARCHITEKTIN"
    },
    image: "/images/about/iulia.jpg",
    bio: {
      en: "Iulia is an architect from The Sapienza University of Rome, has pursued her studies between Rome, Paris, and Moscow, where she won a scholarship for her final project. At S’Estepa Design, she specialises in translating our designs onto paper. With her ability to create 3D and 2D designs, Iulia brings projects to life before they become a reality, allowing our clients to visualise their future garden with great precision.",
      es: "Iulia es arquitecta por la Universidad Sapienza de Roma y ha cursado sus estudios entre Roma, París y Moscú, donde obtuvo una beca para su proyecto final. En S’Estepa Design, se especializa en plasmar nuestros diseños sobre el papel. Gracias a su destreza en el modelado 3D y planos 2D, Iulia da vida a los proyectos antes de su ejecución, permitiendo a nuestros clientes visualizar su futuro jardín con extraordinaria precisión.",
      de: "Iulia ist Architektin der Universität Sapienza in Rom und hat ihr Studium zwischen Rom, Paris und Moskau absolviert, wo sie ein Stipendium für ihr Abschlussprojekt erhielt. Bei S'Estepa Design ist sie darauf spezialisiert, unsere Entwürfe auf Papier zu bringen. Mit ihrer Fähigkeit, 3D- und 2D-Designs zu erstellen, erweckt Iulia Projekte zum Leben, noch bevor sie Realität werden, sodass sich unsere Kunden ihr zukünftiges Paradies detailgetreu vorstellen können."
    }
  },
  {
    name: "Miguel Llabres",
    role: {
      en: "SITE MANAGER",
      es: "JEFE DE OBRA",
      de: "BAULEITER"
    },
    image: "/images/about/miguel.jpg",
    bio: {
      en: "Miguel plays an essential role in the management and development of gardens, focusing on their construction and addressing our clients’ concerns on-site. His technical knowledge and skills enable him to make adjustments on the fly and resolve any issues that may arise during the construction process. Being present during construction allows him to interact directly with clients, answer questions, and address any concerns they may have.",
      es: "Miguel desempeña un papel fundamental en la ejecución y desarrollo de los jardines, centrándose en su construcción física y en atender las necesidades de los clientes sobre el terreno. Sus conocimientos técnicos le permiten realizar ajustes sobre la marcha y resolver cualquier eventualidad en la fase de obra. Su presencia constante en los trabajos facilita la comunicación directa con los clientes, resolviendo dudas y asegurando un proceso sin fisuras.",
      de: "Miguel spielt eine wesentliche Rolle bei der Umsetzung und Entwicklung der Gärten, wobei sein Schwerpunkt auf dem Bau und der Betreuung vor Ort liegt. Sein technisches Wissen und seine Fähigkeiten ermöglichen es ihm, Anpassungen spontan vorzunehmen und eventuelle Herausforderungen während der Bauphase sofort zu lösen. Seine ständige Präsenz auf der Baustelle ermöglicht den direkten Kontakt mit den Kunden, um Fragen und Wünsche direkt zu klären."
    }
  }
];
---

<Layout title={`S'Estepa Design | ${t('about.title')}`} description={pageDescription} lang={lang}>
  <!-- Subpage Header -->
  <section class="subpage-header">
    <div class="container header-grid">
      <div class="header-text">
        <span class="header-tag">{t('nav.about')}</span>
        <h1 class="header-title">{t('about.title')}</h1>
        <p class="header-subtitle">{t('about.subtitle')}</p>
      </div>
      <div class="header-image-container">
        <img src="/images/about/studio-street.jpg" alt="S'Estepa Design Studio" class="header-image" />
      </div>
    </div>
  </section>

  <!-- Ethos & Vision Section -->
  <section class="ethos section-padding">
    <div class="container ethos-container">
      <span class="section-tag center">Our Ethos</span>
      <h2 class="ethos-title-heading center">{ethosTitle[lang]}</h2>
      
      <blockquote class="ethos-quote">
        "Gardens can take years to fully develop into the ultimate concept, so it's important to take it slow and respect the rhythm of nature"
        <cite>&mdash; Pedro Campaner</cite>
      </blockquote>

      <div class="ethos-grid">
        <div class="ethos-col">
          <p class="lead-text">{ethosMainText[lang]}</p>
        </div>
        <div class="ethos-col">
          <p>{ethosSubText[lang]}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="team section-padding">
    <div class="container">
      <span class="section-tag center">The Team</span>
      <h2 class="team-title center">{teamSectionTitle[lang]}</h2>
      <p class="team-subtitle center">{teamSectionSubtitle[lang]}</p>

      <div class="team-grid">
        {team.map(member => (
          <div class="team-card">
            <div class="team-img-wrapper">
              <img src={member.image} alt={`${member.name} - ${member.role[lang]}`} class="team-img" />
            </div>
            <div class="team-info">
              <span class="team-role">{member.role[lang]}</span>
              <h3 class="team-name">{member.name}</h3>
              <p class="team-bio">{member.bio[lang]}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Subpage Header */
  .subpage-header {
    background-color: var(--color-sand-light);
    padding: 12rem 0 6rem 0;
    border-bottom: 1px solid var(--color-sand-dark);
  }

  .header-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .header-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .header-tag {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-olive);
  }

  .header-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--color-charcoal);
  }

  .header-subtitle {
    font-size: 1.25rem;
    color: var(--color-charcoal-light);
    line-height: 1.6;
    font-weight: 300;
  }

  .header-image-container {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--color-sand-base);
    border: 1px solid var(--color-sand-dark);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.03);
  }

  .header-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .header-image-container:hover .header-image {
    transform: scale(1.03);
  }

  @media (max-width: 992px) {
    .subpage-header {
      padding: 10rem 0 4rem 0;
    }

    .header-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .header-image-container {
      aspect-ratio: 16 / 9;
      max-height: 350px;
    }
  }

  /* Ethos Section */
  .ethos {
    background-color: var(--color-white);
  }

  .ethos-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .section-tag {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-olive);
    display: block;
    margin-bottom: 1rem;
  }

  .ethos-title-heading {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 3rem;
    color: var(--color-charcoal);
  }

  .ethos-quote {
    font-size: 1.25rem;
    line-height: 1.8;
    font-weight: 300;
    text-align: center;
    color: var(--color-charcoal-light);
    margin: 3rem 0;
    font-style: italic;
    border: none;
    padding: 0;
  }

  .ethos-quote cite {
    display: block;
    font-size: 0.9rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-olive);
    margin-top: 1rem;
    font-style: normal;
  }

  .ethos-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-top: 3rem;
    border-top: 1px solid var(--color-sand-dark);
    padding-top: 3rem;
  }

  .ethos-col p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-charcoal-light);
  }

  .ethos-col p.lead-text {
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--color-olive);
  }

  /* Team Section */
  .team {
    background-color: var(--color-sand-light);
    border-top: 1px solid var(--color-sand-dark);
  }

  .team-title {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    margin-bottom: 1rem;
  }

  .team-subtitle {
    font-size: 1.1rem;
    color: var(--color-charcoal-light);
    max-width: 700px;
    line-height: 1.6;
    margin-bottom: 5rem;
    font-weight: 300;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem 2rem;
  }

  .team-card {
    background-color: var(--color-white);
    border: 1px solid rgba(227, 221, 211, 0.4);
    transition: var(--transition-medium);
    display: flex;
    flex-direction: column;
  }

  .team-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.03);
  }

  .team-img-wrapper {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background-color: var(--color-sand-base);
  }

  .team-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .team-card:hover .team-img {
    transform: scale(1.05);
  }

  .team-info {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .team-role {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-olive);
    text-transform: uppercase;
  }

  .team-name {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--color-charcoal);
  }

  .team-bio {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-charcoal-light);
  }

  @media (max-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 2rem;
    }
  }

  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .team-img-wrapper {
      aspect-ratio: 16 / 9;
    }

    .ethos-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-top: 2rem;
      margin-top: 2rem;
    }

    .team-info {
      padding: 2rem;
    }
  }
</style>
