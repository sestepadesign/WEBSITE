---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../data/translations';
import { servicesContent } from '../../data/services';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }, { params: { lang: 'de' } }];
}

const { lang } = Astro.params as { lang: 'en' | 'es' | 'de' };
const content = servicesContent[lang];

const t = (key: keyof (typeof ui)[typeof lang]) => ui[lang][key] || key;
---

<Layout
  title={`S'Estepa Design | ${content.title}`}
  description={content.metaDescription}
  lang={lang}
  image="/portfolio/campos/cover.webp"
>
  <article class="services-page section-padding">
    <div class="container">
      <header class="page-header">
        <span class="section-tag">{content.tag}</span>
        <h1 class="page-title">{content.title}</h1>
        <p class="page-subtitle">{content.subtitle}</p>
        <p class="page-intro">{content.intro}</p>
      </header>

      <div class="services-grid">
        {content.items.map((item) => (
          <section class="service-card">
            <h2 class="service-title">{item.title}</h2>
            <p class="service-text">{item.text}</p>
            <a href={`/${lang}/${item.linkUrl}/`} class="service-link">
              {item.linkText} &rarr;
            </a>
          </section>
        ))}
      </div>

      <div class="cta-panel">
        <p>
          {lang === 'en' && 'Mediterranean gardens with an authentic Mallorcan DNA.'}
          {lang === 'es' && 'Jardines mediterráneos con un ADN mallorquín auténtico.'}
          {lang === 'de' && 'Mediterrane Gärten mit authentischer mallorquinischer DNA.'}
        </p>
        <a href={`/${lang}/contact/`} class="cta-button">
          {t('contact.form.submit')}
        </a>
      </div>
    </div>
  </article>
</Layout>

<style>
  .page-header {
    max-width: 820px;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    margin: 1rem 0;
    color: var(--color-charcoal);
  }

  .page-subtitle,
  .page-intro {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-charcoal-light);
  }

  .page-intro {
    margin-top: 1.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .service-card {
    background: var(--color-white);
    padding: 2.5rem;
    border: 1px solid var(--color-sand-dark);
  }

  .service-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 1rem;
    color: var(--color-olive);
  }

  .service-text {
    line-height: 1.75;
    color: var(--color-charcoal-light);
    margin-bottom: 1.5rem;
  }

  .service-link {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-charcoal);
    border-bottom: 1px solid var(--color-olive);
    padding-bottom: 0.2rem;
  }

  .cta-panel {
    text-align: center;
    padding: 3rem;
    background: var(--color-sand-base);
  }

  .cta-panel p {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    margin-bottom: 1.5rem;
    color: var(--color-charcoal);
  }

  .cta-button {
    display: inline-block;
    padding: 0.9rem 2rem;
    background: var(--color-olive);
    color: var(--color-white);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
