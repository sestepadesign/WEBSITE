---
import { GTM_ID, GOOGLE_ADS_ID, GTAG_ID, METRICOOL_HASH } from '../lib/seo';
import { getPagePath } from '../lib/urls';

interface Props {
  lang: 'en' | 'es' | 'de';
}

const { lang } = Astro.props;
const cookiesUrl = getPagePath('cookies', lang);

const copy = {
  en: {
    text: 'We use essential cookies for site operation. With your consent, we also use analytics cookies to understand how visitors use our website (Google Analytics, Google Ads, Metricool). You can accept or reject non-essential cookies.',
    accept: 'Accept',
    reject: 'Reject',
    policy: 'Cookie policy',
  },
  es: {
    text: 'Utilizamos cookies esenciales para el funcionamiento del sitio. Con su consentimiento, también usamos cookies analíticas para entender cómo los visitantes utilizan nuestra web (Google Analytics, Google Ads, Metricool). Puede aceptar o rechazar las cookies no esenciales.',
    accept: 'Aceptar',
    reject: 'Rechazar',
    policy: 'Política de cookies',
  },
  de: {
    text: 'Wir verwenden essentielle Cookies für den Betrieb der Website. Mit Ihrer Zustimmung nutzen wir zusätzlich Analyse-Cookies, um zu verstehen, wie Besucher unsere Website nutzen (Google Analytics, Google Ads, Metricool). Sie können nicht essentielle Cookies akzeptieren oder ablehnen.',
    accept: 'Akzeptieren',
    reject: 'Ablehnen',
    policy: 'Cookie-Richtlinie',
  },
}[lang];
---

<div
  id="cookie-consent"
  class="cookie-consent"
  role="dialog"
  aria-live="polite"
  aria-label={copy.policy}
  style="display: none;"
  hidden
>
  <div class="cookie-consent-inner">
    <p class="cookie-consent-text">
      {copy.text}
      <a href={cookiesUrl} class="cookie-consent-link">{copy.policy}</a>
    </p>
    <div class="cookie-consent-actions">
      <button type="button" class="cookie-btn cookie-btn-reject" id="cookie-reject">
        {copy.reject}
      </button>
      <button type="button" class="cookie-btn cookie-btn-accept" id="cookie-accept">
        {copy.accept}
      </button>
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{
    gtmId: GTM_ID,
    gtagId: GTAG_ID,
    adsId: GOOGLE_ADS_ID,
    metricoolHash: METRICOOL_HASH,
    consentKey: 'sestepa-cookie-consent',
  }}
>
  (function () {
    var banner = document.getElementById('cookie-consent');
    var acceptBtn = document.getElementById('cookie-accept');
    var rejectBtn = document.getElementById('cookie-reject');
    if (!banner || !acceptBtn || !rejectBtn) return;

    function readConsent() {
      try {
        var stored = localStorage.getItem(consentKey);
        if (stored === 'accepted' || stored === 'rejected') return stored;
      } catch (e) {}
      var match = document.cookie.match(new RegExp('(?:^|; )' + consentKey + '=([^;]*)'));
      if (match && (match[1] === 'accepted' || match[1] === 'rejected')) return match[1];
      return null;
    }

    function storeConsent(value) {
      try {
        localStorage.setItem(consentKey, value);
      } catch (e) {}
      var secure = location.protocol === 'https:' ? '; Secure' : '';
      document.cookie =
        consentKey + '=' + value + '; path=/; max-age=31536000; SameSite=Lax' + secure;
    }

    function hideBanner() {
      banner.style.display = 'none';
      banner.hidden = true;
      banner.setAttribute('aria-hidden', 'true');
    }

    function showBanner() {
      banner.style.display = 'block';
      banner.hidden = false;
      banner.removeAttribute('aria-hidden');
    }

    function loadGtm() {
      if (window.__sestepaGtmLoaded) return;
      window.__sestepaGtmLoaded = true;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
      var f = document.getElementsByTagName('script')[0];
      var j = document.createElement('script');
      j.async = true;
      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + gtmId;
      f.parentNode.insertBefore(j, f);
    }

    function loadGtag() {
      if (window.__sestepaGtagLoaded) return;
      window.__sestepaGtagLoaded = true;
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        window.dataLayer.push(arguments);
      }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', gtagId);
      gtag('config', adsId);
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gtagId;
      document.head.appendChild(s);
    }

    function loadMetricool() {
      if (window.__sestepaMetricoolLoaded) return;
      window.__sestepaMetricoolLoaded = true;
      var head = document.getElementsByTagName('head')[0];
      var script = document.createElement('script');
      script.type = 'text/javascript';
      script.src = 'https://tracker.metricool.com/app/resources/be.js';
      script.onload = function () {
        if (window.beTracker) {
          window.beTracker.t({ hash: metricoolHash });
        }
      };
      head.appendChild(script);
    }

    function loadAnalytics() {
      loadGtm();
      loadGtag();
      loadMetricool();
    }

    function acceptCookies() {
      storeConsent('accepted');
      hideBanner();
      loadAnalytics();
    }

    function rejectCookies() {
      storeConsent('rejected');
      hideBanner();
    }

    acceptBtn.addEventListener('click', acceptCookies);
    rejectBtn.addEventListener('click', rejectCookies);

    var consent = readConsent();
    if (consent === 'accepted') {
      hideBanner();
      loadAnalytics();
    } else if (consent === 'rejected') {
      hideBanner();
    } else {
      showBanner();
    }
  })();
</script>

<style>
  .cookie-consent {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: var(--color-sand-base);
    border-top: 1px solid var(--color-sand-dark);
    box-shadow: 0 -8px 32px rgba(31, 33, 31, 0.08);
    padding: 1rem 1.5rem;
  }

  .cookie-consent[hidden] {
    display: none;
  }

  .cookie-consent-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cookie-consent-text {
    flex: 1 1 320px;
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-charcoal-light);
    font-weight: 300;
  }

  .cookie-consent-link {
    color: var(--color-olive);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-left: 0.25rem;
  }

  .cookie-consent-link:hover {
    color: var(--color-olive-dark);
  }

  .cookie-consent-actions {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .cookie-btn {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.85rem 1.5rem;
    border-radius: 0;
    cursor: pointer;
    transition: var(--transition-fast);
    border: 1px solid transparent;
  }

  .cookie-btn-reject {
    background: transparent;
    color: var(--color-charcoal);
    border-color: var(--color-charcoal);
  }

  .cookie-btn-reject:hover {
    border-color: var(--color-olive);
    color: var(--color-olive-dark);
  }

  .cookie-btn-accept {
    background: var(--color-olive);
    color: var(--color-white);
    border-color: var(--color-olive);
  }

  .cookie-btn-accept:hover {
    background: var(--color-olive-dark);
    border-color: var(--color-olive-dark);
  }

  @media (max-width: 768px) {
    .cookie-consent {
      padding: 1.25rem;
    }

    .cookie-consent-inner {
      flex-direction: column;
      align-items: stretch;
      gap: 1.25rem;
    }

    .cookie-consent-text {
      flex: none;
      text-align: center;
      margin-bottom: 0.25rem;
    }

    .cookie-consent-actions {
      justify-content: stretch;
      gap: 0.5rem;
    }

    .cookie-btn {
      flex: 1;
      padding: 0.75rem 1.2rem;
    }
  }
</style>
