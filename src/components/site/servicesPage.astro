<style>
  .services-page {
    padding-top: 10rem;
  }

  @media (max-width: 768px) {
    .services-page {
      padding-top: 8rem;
    }
  }

  .page-header {
    max-width: 820px;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    margin: 1rem 0;
    color: var(--color-charcoal);
  }

  .page-subtitle,
  .page-intro {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-charcoal-light);
  }

  .page-intro {
    margin-top: 1.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .service-card {
    background: var(--color-white);
    padding: 2.5rem;
    border: 1px solid var(--color-sand-dark);
  }

  .service-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 1rem;
    color: var(--color-olive);
  }

  .service-text {
    line-height: 1.75;
    color: var(--color-charcoal-light);
    margin-bottom: 1.5rem;
  }

  .service-link {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-charcoal);
    border-bottom: 1px solid var(--color-olive);
    padding-bottom: 0.2rem;
  }

  .cta-panel {
    text-align: center;
    padding: 3rem;
    background: var(--color-sand-base);
  }

  .cta-panel p {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    margin-bottom: 1.5rem;
    color: var(--color-charcoal);
  }

  .cta-button {
    display: inline-block;
    padding: 0.9rem 2rem;
    background: var(--color-olive);
    color: var(--color-white);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  .proceso-section {
    margin-top: 5rem;
    border-top: 1px solid var(--color-sand-dark);
    padding-top: 4rem;
    margin-bottom: 4rem;
  }

  .proceso-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 300;
    color: var(--color-charcoal);
    margin-bottom: 2.5rem;
  }

  .proceso-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 820px;
  }

  .proceso-content p {
    font-size: 0.975rem;
    line-height: 1.85;
    color: var(--color-charcoal-light);
  }

  .proceso-content strong {
    color: var(--color-charcoal);
    font-weight: 500;
  }

  .faq-section {
    margin-top: 5rem;
    border-top: 1px solid var(--color-sand-dark);
    padding-top: 4rem;
  }

  .faq-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 300;
    color: var(--color-charcoal);
    margin-bottom: 3rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-sand-dark);
    padding: 2rem 0;
  }

  .faq-item dt {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-charcoal);
    margin-bottom: 0.75rem;
  }

  .faq-item dd {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-charcoal-light);
    max-width: 740px;
  }
</style>



