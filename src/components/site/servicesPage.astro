---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../data/translations';
import { servicesContent } from '../../data/services';
import { getPagePath } from '../../lib/urls';
import type { SitePageId } from '../../data/site-urls';

interface Props { lang: 'en' | 'es' | 'de'; }
const { lang } = Astro.props;
const content = servicesContent[lang];

const t = (key: keyof (typeof ui)[typeof lang]) => ui[lang][key] || key;
---

<Layout
  title={content.seoTitle || `S'Estepa Design | ${content.title}`}
  description={content.metaDescription}
  lang={lang}
  image="/portfolio/sant-llorenc/images/garden-design-mallorca-sant-llorenc-sestepa.webp"
>
  <article class="services-page section-padding">
    <div class="container">
      <header class="page-header">
        <span class="section-tag">{content.tag}</span>
        <h1 class="page-title">{content.title}</h1>
        <p class="page-subtitle">{content.subtitle}</p>
        <p class="page-intro">{content.intro}</p>
      </header>

      <div class="services-grid">
        {content.items.map((item, index) => (
          <section class="service-card">
            <div class="category-icon-wrapper">
              {index === 0 && (
                <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 21V9l8-5 8 5v12H4z" />
                  <path d="M9 21v-8h6v8" />
                  <path d="M7 9h10" />
                </svg>
              )}
              {index === 1 && (
                <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2v3" />
                  <path d="M12 5L7 20" />
                  <path d="M12 5l5 15" />
                  <path d="M9 14h6" />
                  <circle cx="12" cy="5" r="1.5" />
                </svg>
              )}
              {index === 2 && (
                <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 20H4v-4h16v4z" />
                  <path d="M14 16H4v-4h10v4z" />
                  <path d="M20 16h-6v-4h6v4z" />
                  <path d="M10 12H4V8h6v4z" />
                  <path d="M20 12H10V8h10v4z" />
                </svg>
              )}
              {index === 3 && (
                <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22a7 7 0 0 0 7-7c0-4.3-7-13-7-13S5 10.7 5 15a7 7 0 0 0 7 7z" />
                  <path d="M12 9v9" />
                  <path d="M12 12s2 1.5 2 3" />
                  <path d="M12 14s-2 1.5-2 3" />
                </svg>
              )}
            </div>
            <h2 class="service-title">{item.title}</h2>
            <p class="service-text">{item.text}</p>
          </section>
        ))}
      </div>



      <section class="services-list-section">
        <h2 class="services-list-heading">
          {lang === 'en' && 'Our Services'}
          {lang === 'es' && 'Nuestros Servicios'}
          {lang === 'de' && 'Unsere Leistungen'}
        </h2>
        <ul class="services-bullets">
          {lang === 'es' && (
            <>
              <li>Concepción, ejecución y mantenimiento de jardines y terrazas.</li>
              <li>Análisis previo del terreno y sus condicionantes.</li>
              <li>Propuesta conceptual, compositiva y técnica del jardín.</li>
              <li>Definición del trazado general del jardín y su zonificación.</li>
              <li>Selección y composición de las plantaciones.</li>
              <li>Sugerencia de elementos ornamentales de plantación.</li>
              <li>Propuesta de materiales y elementos para el exterior.</li>
              <li>Proyecto y dimensionado de los sistemas de riego e iluminación.</li>
              <li>Desarrollo de la documentación gráfica del proyecto.</li>
              <li>Elaboración de presupuestos.</li>
              <li>Dirección de obra.</li>
              <li>Consultoría.</li>
            </>
          )}
          {lang === 'en' && (
            <>
              <li>Design, execution, and maintenance of gardens and terraces.</li>
              <li>Prior study of the site and its conditions.</li>
              <li>Conceptual, compositional, and technical garden proposal.</li>
              <li>Design of the general garden layout and zoning.</li>
              <li>Planting design: selection and composition.</li>
              <li>Proposal for ornamental planting elements.</li>
              <li>Proposal for outdoor materials and elements.</li>
              <li>Design and calculation of irrigation and lighting systems.</li>
              <li>Graphic proposal elaboration.</li>
              <li>Budget preparation.</li>
              <li>Project management and site direction.</li>
              <li>Consulting.</li>
            </>
          )}
          {lang === 'de' && (
            <>
              <li>Entwurf, Ausführung und Pflege von Gärten und Terrassen.</li>
              <li>Voruntersuchung des Standorts und seiner Bedingungen.</li>
              <li>Konzeptioneller, gestalterischer und technischer Gartenentwurf.</li>
              <li>Entwurf der allgemeinen Gartenaufteilung und Zonierung.</li>
              <li>Pflanzplanung: Auswahl und Komposition.</li>
              <li>Vorschlag für ornamentale Pflanzenelemente.</li>
              <li>Vorschlag für Materialien und Außenelemente.</li>
              <li>Planung und Berechnung von Bewässerungs- und Beleuchtungssystemen.</li>
              <li>Erstellung von grafischen Vorschlägen.</li>
              <li>Budgeterstellung.</li>
              <li>Bauleitung.</li>
              <li>Beratung.</li>
            </>
          )}
        </ul>
      </section>

      <div class="cta-panel">
        <p>
          {lang === 'en' && 'Mediterranean gardens with an authentic Mallorcan DNA.'}
          {lang === 'es' && 'Jardines mediterráneos con un ADN mallorquín auténtico.'}
          {lang === 'de' && 'Mediterrane Gärten mit authentischer mallorquinischer DNA.'}
        </p>
        <a href={getPagePath('contact', lang)} class="cta-button">
          {t('contact.form.submit')}
        </a>
      </div>
</Layout>

<style>
  .services-page {
    padding-top: 10rem;
  }

  @media (max-width: 768px) {
    .services-page {
      padding-top: 8rem;
    }
  }

  .page-header {
    max-width: 820px;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    margin: 1rem 0;
    color: var(--color-charcoal);
  }

  .page-subtitle,
  .page-intro {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-charcoal-light);
  }

  .page-intro {
    margin-top: 1.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .service-card {
    background: var(--color-white);
    padding: 2.5rem 2rem;
    border: 1px solid var(--color-sand-dark);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .category-icon-wrapper {
    margin-bottom: 2rem;
  }

  .service-icon {
    width: 28px;
    height: 28px;
    color: var(--color-olive);
  }

  .service-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 1rem;
    color: var(--color-olive);
  }

  .service-text {
    line-height: 1.75;
    color: var(--color-charcoal-light);
    margin-bottom: 1.5rem;
  }

  .service-link {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-charcoal);
    border-bottom: 1px solid var(--color-olive);
    padding-bottom: 0.2rem;
  }

  .cta-panel {
    text-align: center;
    padding: 3rem;
    background: var(--color-sand-base);
    margin-top: 5rem;
  }

  .cta-panel p {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    margin-bottom: 1.5rem;
    color: var(--color-charcoal);
  }

  .cta-button {
    display: inline-block;
    padding: 0.9rem 2rem;
    background: var(--color-olive);
    color: var(--color-white);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  .services-list-section {
    margin-top: 5rem;
    border-top: 1px solid var(--color-sand-dark);
    padding-top: 4rem;
  }

  .services-list-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 300;
    color: var(--color-charcoal);
    margin-bottom: 2.5rem;
  }

  .services-bullets {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem 2rem;
    padding-left: 0;
    list-style: none;
  }

  @media (max-width: 1024px) {
    .services-bullets {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-bullets {
      grid-template-columns: 1fr;
    }
  }

  .services-bullets li {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-charcoal-light);
    position: relative;
    padding-left: 1.5rem;
  }

  .services-bullets li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--color-olive);
    font-size: 1.25rem;
  }
</style>



