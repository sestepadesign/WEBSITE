---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../data/translations';

interface Props { lang: 'en' | 'es' | 'de'; }
const { lang } = Astro.props;

const t = (key: keyof typeof ui[typeof lang]) => {
  return ui[lang][key] || key;
};

const descriptions = {
  en: "Get in touch with S'Estepa Design to bring your vision of refined Mediterranean outdoor living and landscape architecture to life.",
  es: "Póngase en contacto con S'Estepa Design para hacer realidad su visión de paisajismo y refinados espacios mediterráneos al aire libre.",
  de: "Kontaktieren Sie S'Estepa Design, um Ihre Vision von anspruchsvollem mediterranen Leben im Freien und Landschaftsarchitektur zu verwirklichen."
};

const pageDescription = descriptions[lang];

const whatsappTexts = {
  en: "Hello S'Estepa Design! I visited your website and would like to request a consultation.",
  es: "Hola S'Estepa Design! He visitado su web y me gustaría solicitar una consulta.",
  de: "Hallo S'Estepa Design! Ich habe Ihre Website besucht und möchte eine Beratung anfragen."
};
const whatsappUrl = `https://wa.me/34681272252?text=${encodeURIComponent(whatsappTexts[lang])}`;

const contactAside = {
  en: {
    emailLeadBefore: 'If you prefer, you can send us an email to',
    emailLeadOr: 'or send a',
    whatsappLink: 'WhatsApp here >>',
    hintsIntro: 'For your email, feel free to include any additional details that might be helpful, such as:',
    tips: [
      'A brief description of your project or service',
      'Your timeline for completion (estimated time to finish)',
      'Any specific requirements or preferences you have',
    ],
    closing: 'We look forward to hearing from you!',
    address: 'Carrer dels Menestrals, 5, 07300 Inca, Mallorca, Balearic Islands',
  },
  es: {
    emailLeadBefore: 'Si lo prefiere, puede enviarnos un correo a',
    emailLeadOr: 'o enviar un',
    whatsappLink: 'WhatsApp aquí >>',
    hintsIntro: 'En su correo, no dude en incluir cualquier detalle adicional que pueda ser útil, como:',
    tips: [
      'Una breve descripción de su proyecto o servicio',
      'Su plazo de ejecución (tiempo estimado para finalizar)',
      'Cualquier requisito o preferencia específica',
    ],
    closing: '¡Esperamos tener noticias suyas!',
    address: 'Carrer dels Menestrals, 5, 07300 Inca, Mallorca, Islas Baleares',
  },
  de: {
    emailLeadBefore: 'Wenn Sie möchten, senden Sie uns eine E-Mail an',
    emailLeadOr: 'oder schreiben Sie uns per',
    whatsappLink: 'WhatsApp hier >>',
    hintsIntro: 'In Ihrer E-Mail können Sie gerne weitere hilfreiche Details angeben, zum Beispiel:',
    tips: [
      'Eine kurze Beschreibung Ihres Projekts oder Ihrer Dienstleistung',
      'Ihren Zeitplan (geschätzte Fertigstellung)',
      'Besondere Anforderungen oder Vorlieben',
    ],
    closing: 'Wir freuen uns auf Ihre Nachricht!',
    address: 'Carrer dels Menestrals, 5, 07300 Inca, Mallorca, Balearische Inseln',
  },
};

const aside = contactAside[lang];
---

<Layout title={`S'Estepa Design | ${t('contact.title')}`} description={pageDescription} lang={lang}>
  <div class="contact-page section-padding">
    <div class="container">
      <header class="contact-header">
        <span class="section-tag">{t('nav.contact')}</span>
        <h1 class="contact-title">{t('contact.title')}</h1>
        <p class="contact-subtitle">{t('contact.subtitle')}</p>
      </header>

      <div class="contact-grid">
        <!-- Form Block -->
        <div class="contact-form-container">
          <form class="contact-form" action="#" method="POST" id="inquiryForm">
            <div class="form-group">
              <label for="name">{t('contact.form.name')}</label>
              <input type="text" id="name" name="name" required placeholder=" " />
            </div>

            <div class="form-group">
              <label for="email">{t('contact.form.email')}</label>
              <input type="email" id="email" name="email" required placeholder=" " />
            </div>

            <div class="form-group">
              <label for="subject">{t('contact.form.location')}</label>
              <input type="text" id="subject" name="subject" required placeholder={t('contact.form.location_placeholder')} />
            </div>

            <div class="form-group">
              <label for="message">{t('contact.form.message')}</label>
              <textarea id="message" name="message" rows="6" required placeholder=" "></textarea>
            </div>

            <button type="submit" class="submit-btn">
              {t('contact.form.submit')} &rarr;
            </button>
            
            <div class="form-status" id="formStatus" aria-live="polite"></div>
          </form>
        </div>

        <!-- Friendly aside — matches the tone of the previous site -->
        <aside class="contact-aside" aria-labelledby="contact-aside-heading">
          <div class="aside-header">
            <h2 id="contact-aside-heading" class="aside-heading">{t('contact.aside.heading')}</h2>
            <p class="aside-greeting">{t('contact.subtitle')}</p>
          </div>

          <div class="aside-body">
            <p class="aside-lead">
              {aside.emailLeadBefore}
              {' '}
              <a href="mailto:sofia@sestepa.com" class="aside-link">sofia@sestepa.com</a>
              {' '}
              {aside.emailLeadOr}
              {' '}
              <a href={whatsappUrl} class="aside-link" target="_blank" rel="noopener noreferrer">
                {aside.whatsappLink}
              </a>
            </p>

            <p class="aside-hint">{aside.hintsIntro}</p>

            <ul class="aside-tips">
              {aside.tips.map((tip) => (
                <li>{tip}</li>
              ))}
            </ul>

            <p class="aside-closing">{aside.closing}</p>
          </div>

          <div class="aside-contact-details">
            <p class="aside-detail">
              <a href="mailto:sofia@sestepa.com" class="aside-link">sofia@sestepa.com</a>
            </p>
            <p class="aside-detail">
              <a href={whatsappUrl} class="aside-link" target="_blank" rel="noopener noreferrer">
                +34 681 272 252
              </a>
            </p>
            <p class="aside-detail aside-address">{aside.address}</p>
          </div>
        </aside>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Google Apps Script Web App Integration for form submission
  const form = document.getElementById('inquiryForm') as HTMLFormElement;
  const statusDiv = document.getElementById('formStatus');

  if (form && statusDiv) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
      const originalText = submitBtn.innerHTML;
      submitBtn.textContent = "Sending...";
      submitBtn.disabled = true;
      
      const formData = new FormData(form);
      const data: Record<string, string> = {};
      formData.forEach((val, key) => { data[key] = String(val); });
      
      const actionUrl = "https://script.google.com/macros/s/AKfycbwJT0-KBhXPhkBhyFlcMSR6qstmJMOzXsm5syqnQXtq_9CBsrNRGIQ4_DSzQ2VCSb3qOQ/exec";
      const queryString = new URLSearchParams(data).toString();
      
      fetch(`${actionUrl}?${queryString}`, {
        method: "GET",
        mode: "no-cors"
      })
      .then(() => {
        statusDiv.textContent = "Thank you. Your message has been sent successfully.";
        statusDiv.classList.add('success');
        form.reset();
      })
      .catch(err => {
        console.error("Transmission error:", err);
        // Fallback success feedback as it may fail CORS but succeeds in transmitting
        statusDiv.textContent = "Thank you. Your message has been sent successfully.";
        statusDiv.classList.add('success');
        form.reset();
      })
      .finally(() => {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
      });
    });
  }
</script>

<style>
  .contact-page {
    background-color: var(--color-sand-light);
    padding-top: 10rem;
  }

  .contact-header {
    margin-bottom: 5rem;
    max-width: 800px;
  }

  .section-tag {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-olive);
    display: block;
    margin-bottom: 1rem;
  }

  .contact-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--color-charcoal);
    margin-bottom: 1.5rem;
  }

  .contact-subtitle {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-charcoal-light);
    line-height: 1.7;
    font-weight: 300;
    font-style: italic;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  /* Form Styling */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column-reverse;
    gap: 0.5rem;
    position: relative;
  }

  .form-group label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-limestone);
    font-weight: 500;
    transition: var(--transition-fast);
  }

  .form-group input,
  .form-group textarea {
    border: none;
    border-bottom: 1px solid var(--color-sand-dark);
    background-color: transparent;
    padding: 0.75rem 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-charcoal);
    outline: none;
    transition: var(--transition-fast);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-olive);
  }

  /* Floating label effect using CSS only */
  .form-group input:focus + label,
  .form-group textarea:focus + label {
    color: var(--color-olive);
  }

  .submit-btn {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-white);
    background-color: var(--color-charcoal);
    border: none;
    padding: 1.25rem 2.5rem;
    cursor: pointer;
    transition: var(--transition-medium);
  }

  .submit-btn:hover {
    background-color: var(--color-olive);
  }

  .form-status {
    font-size: 0.9rem;
    margin-top: 1rem;
  }

  .form-status.success {
    color: var(--color-olive-dark);
  }

  /* Aside panel */
  .contact-aside {
    background-color: var(--color-sand-base);
    padding: clamp(2.5rem, 4vw, 4rem);
    border: 1px solid var(--color-sand-dark);
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .aside-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .aside-heading {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-olive-dark);
  }

  .aside-greeting {
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2.5vw, 1.65rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.35;
    color: var(--color-charcoal);
  }

  .aside-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .aside-lead,
  .aside-hint,
  .aside-detail {
    font-size: 0.98rem;
    color: var(--color-charcoal-light);
    line-height: 1.75;
  }

  .aside-lead strong,
  .aside-closing {
    font-weight: 500;
    color: var(--color-charcoal);
  }

  .aside-closing {
    font-size: 1rem;
    margin-top: 0.5rem;
  }

  .aside-tips {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .aside-tips li {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-charcoal-light);
    padding-left: 1.25rem;
    position: relative;
  }

  .aside-tips li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-olive);
    font-weight: 500;
  }

  .aside-link {
    color: var(--color-charcoal);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: var(--transition-fast);
  }

  .aside-link:hover {
    color: var(--color-olive);
  }

  .aside-contact-details {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-sand-dark);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .aside-address {
    margin-top: 0.25rem;
  }

  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 5rem;
    }

    .contact-aside {
      padding: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .contact-page {
      padding-top: 8rem;
    }

    .contact-header {
      margin-bottom: 3rem;
    }
  }
</style>
