---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../data/translations';
import { projects } from '../../data/projects';
import ProjectCard from '../ProjectCard.astro';
import { getPagePath, getProjectPath } from '../../lib/urls';

interface Props { lang: 'en' | 'es' | 'de'; }
const { lang } = Astro.props;

const t = (key: keyof typeof ui[typeof lang]) => {
  return ui[lang][key] || key;
};

// SEO meta description
const descriptions = {
  en: "S'Estepa Design &mdash; boutique garden design and landscape architecture studio in Mallorca. Where the outdoors becomes your favourite room in the house.",
  es: "S'Estepa Design &mdash; estudio boutique de diseño de jardines y arquitectura del paisaje en Mallorca. Donde el exterior se convierte en su espacio favorito.",
  de: "S'Estepa Design &mdash; exklusives Gartendesign und Landschaftsarchitektur Studio auf Mallorca. Wo der Außenbereich zu Ihrem Lieblingsraum wird.",
};

// SEO page titles &mdash; keyword-first, separate from hero.subtitle (visible text unchanged)
const seoTitles = {
  en: "S'Estepa Design: Garden & Landscape Design in Mallorca",
  es: "S'Estepa Design: Diseño de Jardines y Paisajismo en Mallorca",
  de: "S'Estepa Design: Gartengestaltung & Landschaftsarchitektur Mallorca",
};

const pageDescription = descriptions[lang];

const whatsappTexts = {
  en: "Hello S'Estepa Design! I visited your website and would like to request a consultation.",
  es: "Hola S'Estepa Design! He visitado su web y me gustaría solicitar una consulta.",
  de: "Hallo S'Estepa Design! Ich habe Ihre Website besucht und möchte eine Beratung anfragen."
};
const whatsappUrl = `https://wa.me/34681272252?text=${encodeURIComponent(whatsappTexts[lang])}`;

// Featured projects &mdash; 2×2 grid: Crestatx + Llubí, Terrace Palma + Sa Ponsa
const featuredSlugs = [
  'crestatx-garden-design',
  'garden-design-llubi-mallorca',
  'terrace-garden-in-palma',
  'santa-ponsa',
];
const featuredProjects = featuredSlugs
  .map((slug) => projects.find((p) => p.slug === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
const camposProject = projects.find((p) => p.slug === 'finca-garden-campos-mallorca');
const santLlorencProject = projects.find((p) => p.slug === 'sant-llorenc');

const camposSpotlightImage = camposProject?.cover ?? '';

const spotlightCopy = {
  en: {
    tag: 'Featured Estate',
    title: 'Finca Garden Campos',
    text: 'An exceptional landscape in Campos &mdash; one of our largest estate gardens, designed and built by S\'Estepa across mathematical planting, natural meadows, and hidden garden passages.',
    cta: 'Explore the full project',
    size: '',
  },
  es: {
    tag: 'Finca Destacada',
    title: 'Finca Jardín Campos',
    text: 'Un paisaje excepcional en Campos &mdash; uno de nuestros jardines de finca más grandes, diseñado y construido por S\'Estepa con plantación matemática, praderas naturales y pasajes ocultos.',
    cta: 'Explorar el proyecto completo',
    size: '',
  },
  de: {
    tag: 'Ausgewähltes Landgut',
    title: 'Finca Garten Campos',
    text: 'Eine außergewöhnliche Landschaft in Campos &mdash; einer unserer größten Landgutgärten, entworfen und gebaut von S\'Estepa mit mathematischer Bepflanzung, natürlichen Wiesen und verborgenen Gartenpassagen.',
    cta: 'Das vollständige Projekt ansehen',
    size: '',
  },
};
const spotlight = spotlightCopy[lang];

const journeyData = {
  en: {
    tag: "Our Landscape Journey Design",
    title: "Your Garden Design",
    subtitle: "A highly refined, collaborative roadmap from initial meeting to a fully realized living environment.",
    steps: [
      {
        num: "01",
        title: "First Meeting",
        text: "An initial meeting to align your vision with the site’s potential. We evaluate the landscape’s unique features, orientation, and your lifestyle requirements to establish the foundation of the project.",
        hasLink: true,
        linkText: "Start the Conversation"
      },
      {
        num: "02",
        title: "Conceptual Design",
        text: "Translating our initial dialogue into a visual narrative. We develop a preliminary concept outlining the spatial layout, material palette, and key botanical features. Depending on the project’s complexity, we provide 2D scaled plans or high-fidelity 3D renders to bring the vision to life."
      },
      {
        num: "03",
        title: "Design Refinement",
        text: "A collaborative dialogue to perfect every detail. We refine the conceptual vision based on your feedback, ensuring the design aligns seamlessly with your lifestyle, functional requirements, and technical specifications."
      },
      {
        num: "04",
        title: "Final Design",
        text: "Once the design concept is finalized, we develop the comprehensive technical plans and specifications required for execution. This stage defines every constructive detail, from the precise selection of hardscape materials to the complete botanical palette, ensuring a rigorous roadmap for the build."
      },
      {
        num: "05",
        title: "Installation",
        text: "Our dedicated local team brings the project to life, managing the entire construction and planting process on-site. We oversee every technical specification to ensure the garden is delivered to our exacting standards, providing a seamless transition from the final plans to a living landscape."
      }
    ]
  },
  es: {
    tag: "Nuestra Trayectoria de Paisajismo",
    title: "Su Diseño de Jardín",
    subtitle: "Una hoja de ruta altamente refinada y colaborativa, desde el primer encuentro hasta un entorno vivo completamente realizado.",
    steps: [
      {
        num: "01",
        title: "Primer Encuentro",
        text: "Una reunión inicial para alinear su visión con el potencial del terreno. Evaluamos las características únicas del paisaje, la orientación y sus requisitos de estilo de vida para establecer las bases del proyecto.",
        hasLink: true,
        linkText: "Iniciar una Conversación"
      },
      {
        num: "02",
        title: "Diseño Conceptual",
        text: "Traducimos nuestro diálogo inicial en una narrativa visual. Desarrollamos un concepto preliminar que define la distribución espacial, la paleta de materiales y los elementos botánicos clave. Según la complejidad del proyecto, proporcionamos planos a escala 2D o renders 3D de alta fidelidad."
      },
      {
        num: "03",
        title: "Refinamiento del Diseño",
        text: "Un diálogo colaborativo para perfeccionar cada detalle. Refinamos la visión conceptual basándonos en sus comentarios, asegurando que el diseño se adapte a su estilo de vida, necesidades funcionales y especificaciones técnicas."
      },
      {
        num: "04",
        title: "Diseño Final",
        text: "Una vez finalizado el concepto de diseño, desarrollamos los planos técnicos completos y las especificaciones para la ejecución. Esta etapa define cada detalle constructivo, desde los materiales hasta la paleta botánica completa, asegurando una hoja de ruta rigurosa para la obra."
      },
      {
        num: "05",
        title: "Instalación",
        text: "Nuestro equipo local dedicado da vida al proyecto, gestionando todo el proceso de construcción y plantación in situ. Supervisamos cada especificación técnica para garantizar que el jardín se entregue según nuestros estándares exigentes, asegurando una transición fluida."
      }
    ]
  },
  de: {
    tag: "Unser Landschaftsweg Design",
    title: "Ihre Gartengestaltung",
    subtitle: "Ein hochgradig verfeinerter, partnerschaftlicher Fahrplan vom ersten Treffen bis zu einer vollendeten lebendigen Umgebung.",
    steps: [
      {
        num: "01",
        title: "Erstes Treffen",
        text: "Ein erstes Gespräch, um Ihre Vision mit dem Potenzial des Standorts abzustimmen. Wir bewerten die einzigartigen Merkmale der Landschaft, die Ausrichtung und Ihre Lebensstil-Anforderungen, um die Grundlage des Projekts zu schaffen.",
        hasLink: true,
        linkText: "Ein Gespräch Beginnen"
      },
      {
        num: "02",
        title: "Konzeptentwurf",
        text: "Übersetzung unseres ersten Dialogs in eine visuelle Erzählung. Wir entwickeln ein vorläufiges Konzept, das die räumliche Aufteilung, die Materialpalette und die wichtigsten botanischen Merkmale umreißt. Je nach Komplexität des Projekts erstellen wir 2D-Pläne oder hochauflösende 3D-Visualisierungen."
      },
      {
        num: "03",
        title: "Detailabstimmung",
        text: "Ein partnerschaftlicher Dialog, um jedes Detail zu perfektionieren. Wir verfeinern den Konzeptentwurf basierend auf Ihrem Feedback und stellen sicher, dass das Design nahtlos zu Ihrem Lebensstil, Ihren funktionalen Anforderungen und den technischen Spezifikationen passt."
      },
      {
        num: "04",
        title: "Ausführungsplanung",
        text: "Sobald das Designkonzept feststeht, erstellen wir die detaillierten technischen Pläne und Spezifikationen, die für die Ausführung erforderlich sind. Diese Phase definiert jedes bauliche Detail, von der präzisen Auswahl der Materialien bis hin zur vollständigen botanischen Palette."
      },
      {
        num: "05",
        title: "Realisierung",
        text: "Unser engagiertes lokales Team erweckt das Projekt zum Leben und leitet den gesamten Bau- und Pflanzprozess vor Ort. Wir überwachen jede technische Spezifikation, um sicherzustellen, dass der Garten nach unseren anspruchsvollen Standards übergeben wird."
      }
    ]
  }
};

const servicesData = {
  en: {
    tag: "Our Expertise",
    title: "Services",
    subtitle: "We provide a comprehensive approach to landscaping in Mallorca, focusing on the creation and long-term maintenance of living ecosystems for villas and holiday residences. Our team oversees the entire process&mdash;from design and construction to technical irrigation and planting. We ensure a seamless experience, managing every detail in English, Spanish, and German.",
    items: [
      {
        title: "Villas & Holiday Homes",
        text: "Exclusive tailor-made botanical environments designed to enrich refined residences, holiday homes, and fincas across Mallorca.",
        linkText: "View Projects",
        linkUrl: "portfolio"
      },
      {
        title: "Landscape Design",
        text: "High-fidelity conceptual drawings, technical layouts, and virtual 3D renders that breathe spatial order and structure into your vision.",
        linkText: "Meet Our Architect",
        linkUrl: "about"
      },
      {
        title: "Full Garden Construction",
        text: "Rigorous site development, structural earthworks, and planting executed by our dedicated team of local professionals.",
        linkText: "Meet Site Manager",
        linkUrl: "about"
      },
      {
        title: "Ecological Care",
        text: "Xeriscape planting schemes, water resource planning, and intelligent drip irrigation systems designed for ultimate sustainability.",
        linkText: "Request Consultation",
        linkUrl: "contact"
      }
    ]
  },
  es: {
    tag: "Nuestra Experiencia",
    title: "Servicios",
    subtitle: "Ofrecemos un enfoque integral del paisajismo en Mallorca, centrándonos en la creación y el mantenimiento a largo plazo de ecosistemas vivos para villas y residencias vacacionales. Nuestro equipo supervisa todo el proceso, desde el diseño y la construcción hasta el riego técnico y la plantación. Garantizamos una experiencia sin fisuras, gestionando cada detalle en inglés, español y alemán.",
    items: [
      {
        title: "Villas y Fincas",
        text: "Entornos botánicos exclusivos y a medida, diseñados para enriquecer distinguidas residencias, villas de vacaciones y fincas en Mallorca.",
        linkText: "Ver Proyectos",
        linkUrl: "portfolio"
      },
      {
        title: "Diseño de Paisaje",
        text: "Planos conceptuales de alta fidelidad, distribuciones técnicas y renders 3D virtuales que aportan orden y estructura espacial a su visión.",
        linkText: "Conozca a la Arquitecta",
        linkUrl: "about"
      },
      {
        title: "Construcción y Obra",
        text: "Desarrollo riguroso de la obra, movimientos de tierra estructurales y plantación ejecutada por nuestro equipo local de profesionales.",
        linkText: "Conozca al Jefe de Obra",
        linkUrl: "about"
      },
      {
        title: "Cuidado Ecológico",
        text: "Diseños de xerojardinería, planificación de recursos hídricos y sistemas inteligentes de riego por goteo para la máxima sostenibilidad.",
        linkText: "Solicitar Consulta",
        linkUrl: "contact"
      }
    ]
  },
  de: {
    tag: "Unsere Expertise",
    title: "Dienstleistungen",
    subtitle: "Wir bieten einen umfassenden Ansatz für die Landschaftsgestaltung auf Mallorca, mit Schwerpunkt auf der Schaffung und langfristigen Pflege lebendiger Ökosysteme für Villen und Feriendomizile. Unser Team überwacht den gesamten Prozess – vom Entwurf und Bau bis hin zur technischen Bewässerung und Bepflanzung. Wir garantieren einen reibungslosen Ablauf und regeln jedes Detail auf Englisch, Spanisch und Deutsch.",
    items: [
      {
        title: "Villen & Feriendomizile",
        text: "Exklusive, maßgeschneiderte botanische Umgebungen, die anspruchsvolle Residenzen, Feriendomizile und Fincas auf ganz Mallorca bereichern.",
        linkText: "Projekte Ansehen",
        linkUrl: "portfolio"
      },
      {
        title: "Landschaftsarchitektur",
        text: "Präzise Konzeptzeichnungen, technische Layouts und virtuelle 3D-Renderings, die Ihrer Vision räumliche Ordnung und Struktur verleihen.",
        linkText: "Treffen Sie die Architektin",
        linkUrl: "about"
      },
      {
        title: "Kompletter Gartenbau",
        text: "Strikte Baustellenentwicklung, strukturelle Erdarbeiten und Pflanzung, ausgeführt von unserem engagierten Team lokaler Fachleute.",
        linkText: "Treffen Sie den Bauleiter",
        linkUrl: "about"
      },
      {
        title: "Ökologische Pflege",
        text: "Xeriscape-Bepflanzungspläne, Wasserressourcenplanung und Tröpfchenbewässerungssysteme für höchste Nachhaltigkeit.",
        linkText: "Beratung Anfragen",
        linkUrl: "contact"
      }
    ]
  }
};

const currentServices = servicesData[lang];
const currentJourney = journeyData[lang];
---

<Layout title={seoTitles[lang]} description={pageDescription} lang={lang}>
  <!-- Hero Section with Background Video -->
  <section class="hero" id="hero-section">
    <div class="video-container">
      <video autoplay loop muted playsinline class="hero-video" poster="/videos/sant_llorenc_poster.webp" aria-hidden="true" id="heroVideo" data-src="/videos/sant_llorenc_hero.mp4">
      </video>
      <div class="hero-overlay"></div>
    </div>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        if (window.innerWidth >= 768) {
          var video = document.getElementById('heroVideo');
          var source = document.createElement('source');
          source.src = video.getAttribute('data-src');
          source.type = 'video/mp4';
          video.appendChild(source);
        }
      });
    </script>
    
    <div class="hero-content container">
      <span class="hero-subtitle">{t('hero.subtitle')}</span>
      <h1 class="hero-title">
        {lang === 'en' && <>Sustainable Mediterranean Gardens</>}
        {lang === 'es' && <>Jardines Mediterráneos Sostenibles</>}
        {lang === 'de' && <>Nachhaltige Mediterrane Gärten</>}
      </h1>
      <a href={getPagePath('portfolio', lang)} class="hero-btn">
        {t('hero.button')} <span class="arrow">&rarr;</span>
      </a>
    </div>
    
    <div class="scroll-indicator">
      <span class="scroll-text">Scroll</span>
      <span class="scroll-line"></span>
    </div>
  </section>

  <!-- Poetry & Philosophy Section -->
  <section class="philosophy section-padding">
    <div class="container philosophy-container">
      <span class="section-tag">{t('about.title')}</span>
      <h2 class="philosophy-title">{t('about.subtitle')}</h2>
      <div class="philosophy-grid">
        <div class="philosophy-text-col">
          {lang === 'en' && (
            <>
              <p>S'Estepa Design projects sustainable ecosystems through a profound understanding of local soils, climate, and endemic flora.</p>
              <p>Inspired by the authentic beauty of the island, we ensure every architectural intervention is an organic extension of Mallorca's natural soul.</p>
            </>
          )}
          {lang === 'es' && (
            <>
              <p>S'Estepa Design proyecta ecosistemas sostenibles a través de un profundo conocimiento de los suelos locales, el clima y la flora endémica.</p>
              <p>Inspirados por la belleza auténtica de la isla, aseguramos que cada intervención arquitectónica sea una extensión orgánica del alma natural de Mallorca.</p>
            </>
          )}
          {lang === 'de' && (
            <>
              <p>S'Estepa Design entwirft nachhaltige Ökosysteme durch ein tiefes Verständnis der lokalen Böden, des Klimas und der endemischen Flora.</p>
              <p>Inspiriert von der authentischen Schönheit der Insel stellen wir sicher, dass jeder architektonische Eingriff eine organische Erweiterung der natürlichen Seele Mallorcas ist.</p>
            </>
          )}
        </div>
        <div class="philosophy-stat-col">
          <div class="stat-box">
            <span class="stat-number">30</span>
            <span class="stat-label">
              {lang === 'en' && "Years of Expertise"}
              {lang === 'es' && "Años de Experiencia"}
              {lang === 'de' && "Jahre Erfahrung"}
            </span>
          </div>
          <div class="stat-box">
            <span class="stat-number">100%</span>
            <span class="stat-label">
              {lang === 'en' && "Mediterranean Soul"}
              {lang === 'es' && "Alma Mediterránea"}
              {lang === 'de' && "Mediterrane Seele"}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Portfolio Grid Section -->
  <section class="featured section-padding">
    <div class="container">
      <div class="featured-header">
        <div>
          <span class="section-tag">{t('portfolio.title')}</span>
          <h2 class="featured-title">
            {lang === 'en' && "Landscape Garden Design Projects"}
            {lang === 'es' && "Proyectos de Diseño de Jardines y Paisajismo"}
            {lang === 'de' && "Landschafts- und Gartengestaltungsprojekte"}
          </h2>
        </div>
        <a href={getPagePath('portfolio', lang)} class="text-link">
          {lang === 'en' && "View all gardens"}
          {lang === 'es' && "Ver todos los jardines"}
          {lang === 'de' && "Alle Gärten ansehen"} &rarr;
        </a>
      </div>

      <div class="projects-grid featured-projects-grid">
        {santLlorencProject && (
          <div class="featured-item featured-item-large">
            <ProjectCard
              slug={santLlorencProject.slug}
              title={santLlorencProject[lang].title}
              category={santLlorencProject[lang].category}
              location={santLlorencProject.location}
              cover={santLlorencProject.cover}
              lang={lang}
              large={true}
              size={santLlorencProject.size}
            />
          </div>
        )}
        {featuredProjects.map((project) => (
          <div class="featured-item">
            <ProjectCard
              slug={project.slug}
              title={project[lang].title}
              category={project[lang].category}
              location={project.location}
              cover={project.cover}
              lang={lang}
              size={project.size}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  {camposProject && (
    <section class="campos-spotlight section-padding">
      <div class="container spotlight-grid">
        <a href={getProjectPath('finca-garden-campos-mallorca', lang)} class="spotlight-image-link">
          <img
            src={camposSpotlightImage}
            alt={camposProject[lang].title}
            class="spotlight-image"
            loading="lazy"
            decoding="async"
          />
        </a>
        <div class="spotlight-text">
          <span class="section-tag">{spotlight.tag}</span>
          <h2 class="spotlight-title">{spotlight.title}</h2>
          {spotlight.size && <p class="spotlight-size">{spotlight.size}</p>}
          <p class="spotlight-desc">{spotlight.text}</p>
          <a href={getProjectPath('finca-garden-campos-mallorca', lang)} class="text-link">
            {spotlight.cta} &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Services Section -->
  <section class="services-section section-padding">
    <div class="container">
      <span class="section-tag center">{currentServices.tag}</span>
      <h2 class="section-heading center">{currentServices.title}</h2>
      <p class="section-desc center">{currentServices.subtitle}</p>
      
      <div class="category-grid">
        {currentServices.items.map((item, index) => (
          <div class="category-card">
            <div class="category-icon-wrapper">
              {index === 0 && (
                <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 21V9l8-5 8 5v12H4z" />
                  <path d="M9 21v-8h6v8" />
                  <path d="M7 9h10" />
                </svg>
              )}
              {index === 1 && (
                <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2v3" />
                  <path d="M12 5L7 20" />
                  <path d="M12 5l5 15" />
                  <path d="M9 14h6" />
                  <circle cx="12" cy="5" r="1.5" />
                </svg>
              )}
              {index === 2 && (
                <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 20H4v-4h16v4z" />
                  <path d="M14 16H4v-4h10v4z" />
                  <path d="M20 16h-6v-4h6v4z" />
                  <path d="M10 12H4V8h6v4z" />
                  <path d="M20 12H10V8h10v4z" />
                </svg>
              )}
              {index === 3 && (
                <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22a7 7 0 0 0 7-7c0-4.3-7-13-7-13S5 10.7 5 15a7 7 0 0 0 7 7z" />
                  <path d="M12 9v9" />
                  <path d="M12 12s2 1.5 2 3" />
                  <path d="M12 14s-2 1.5-2 3" />
                </svg>
              )}
            </div>
            <h3 class="category-title">{item.title}</h3>
            <p class="category-text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Landscape Journey Design Section -->
  <section class="workflow-section">
    <div class="container workflow-container">
      <span class="section-tag center">{currentJourney.tag}</span>
      <h2 class="section-heading center">{currentJourney.title}</h2>
      <p class="section-desc center">{currentJourney.subtitle}</p>

      <div class="workflow-timeline">
        {currentJourney.steps.map((step) => (
          <div class="workflow-step">
            <div class="workflow-num">{step.num}.</div>
            <div class="workflow-content">
              <h3>{step.title}</h3>
              <p class="paragraph">
                {step.text}
                {step.hasLink && (
                  <>
                    {' '}
                    <a href={getPagePath('contact', lang)} class="workflow-link">
                      {step.linkText}
                    </a>
                  </>
                )}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="contact-section section-padding">
    <div class="container">
      <header class="contact-header">
        <span class="section-tag center">{t('nav.contact')}</span>
        <h2 class="section-heading center">{t('contact.title')}</h2>
        <p class="section-desc center">{t('contact.subtitle')}</p>
      </header>

      <div class="contact-grid">
        <!-- Form Block -->
        <div class="contact-form-container">
          <form class="contact-form" action="#" method="POST" id="inquiryForm">
            <div class="form-group">
              <label for="name">{t('contact.form.name')}</label>
              <input type="text" id="name" name="name" required placeholder=" " />
            </div>

            <div class="form-group">
              <label for="email">{t('contact.form.email')}</label>
              <input type="email" id="email" name="email" required placeholder=" " />
            </div>

