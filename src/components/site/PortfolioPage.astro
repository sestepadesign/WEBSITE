---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../data/translations';
import { projects } from '../../data/projects';
import {
  PORTFOLIO_FILTER_ORDER,
  getProjectCategory,
  type PortfolioFilterCategory,
} from '../../data/portfolio-categories';
import ProjectCard from '../ProjectCard.astro';
import PortfolioHero from './PortfolioHero.astro';

interface Props { lang: 'en' | 'es' | 'de'; }
const { lang } = Astro.props;

const t = (key: keyof typeof ui[typeof lang]) => {
  return ui[lang][key] || key;
};

const descriptions = {
  en: "Discover our portfolio of premium landscape design projects in Mallorca, featuring high-end finca gardens, bespoke villas, and refined terraces.",
  es: "Descubra nuestro portafolio de proyectos de paisajismo exclusivo en Mallorca, incluyendo jardines de fincas de alto nivel, villas y terrazas a medida.",
  de: "Entdecken Sie unser Portfolio exklusiver Landschaftsgestaltungsprojekte auf Mallorca, darunter hochwertige Finca-Gärten, Villen und maßgeschneiderte Terrassen."
};

const categoryOrder: Record<PortfolioFilterCategory, number> = {
  estate: 0,
  residential: 1,
  terrace: 2,
  commercial: 3,
  vertical: 4,
};

const GRID_LAST_SLUGS = ['seaside-house-alcudia'] as const;

const portfolioProjects = [...projects].filter((p) => !p.hidden).sort((a, b) => {
  const aLast = GRID_LAST_SLUGS.indexOf(a.slug as typeof GRID_LAST_SLUGS[number]);
  const bLast = GRID_LAST_SLUGS.indexOf(b.slug as typeof GRID_LAST_SLUGS[number]);
  if (aLast !== -1 || bLast !== -1) {
    if (aLast !== -1 && bLast !== -1) return aLast - bLast;
    if (aLast !== -1) return 1;
    return -1;
  }

  const catA = getProjectCategory(a.slug);
  const catB = getProjectCategory(b.slug);
  const catDiff = categoryOrder[catA] - categoryOrder[catB];
  if (catDiff !== 0) return catDiff;
  if (catA === 'estate') {
    if (a.slug === 'sant-llorenc') return -1;
    if (b.slug === 'sant-llorenc') return 1;
    if (a.slug === 'finca-garden-campos-mallorca') return 1;
    if (b.slug === 'finca-garden-campos-mallorca') return -1;
  }
  return 0;
});

const pageDescription = descriptions[lang];

const filterLabels: Record<PortfolioFilterCategory, keyof typeof ui.en> = {
  residential: 'portfolio.filter.residential',
  estate: 'portfolio.filter.estate',
  terrace: 'portfolio.filter.terrace',
  commercial: 'portfolio.filter.commercial',
  vertical: 'portfolio.filter.vertical',
};
---

<Layout title={lang === 'en' ? "Premium Landscape Portfolio Mallorca | Fincas & Villas" : lang === 'es' ? "Portafolio de Paisajismo Exclusivo Mallorca | Fincas y Villas" : "Exklusives Landschaftsportfolio Mallorca | Fincas & Villen"} description={pageDescription} lang={lang}>
  <PortfolioHero lang={lang} />
  <div class="portfolio-page section-padding">
    <div class="container">
      <header class="portfolio-header">
        <span class="section-tag">{t('nav.portfolio')}</span>
        <h1 class="portfolio-title">{t('portfolio.title')}</h1>
        <p class="portfolio-subtitle">{t('portfolio.subtitle')}</p>
      </header>

      <div class="portfolio-filter">
        <button class="filter-btn active" data-filter="all">{t('portfolio.filter.all')}</button>
        {PORTFOLIO_FILTER_ORDER.map((cat) => (
          <button class="filter-btn" data-filter={cat}>
            {t(filterLabels[cat])}
          </button>
        ))}
      </div>

      <div class="projects-grid" id="projectsGrid">
        {portfolioProjects.map((project) => {
          const category = getProjectCategory(project.slug);
          return (
            <div class="project-item-wrapper" data-category={category}>
              <ProjectCard
                slug={project.slug}
                title={project[lang].title}
                category={project[lang].category}
                location={project.location}
                cover={project.cover}
                lang={lang}
                size={project.size}
              />
            </div>
          );
        })}
      </div>
    </div>
  </div>
</Layout>

<script>
  const filterButtons = document.querySelectorAll('.filter-btn');
  const projectItems = document.querySelectorAll('.project-item-wrapper');

  const applyFilter = (filterValue: string) => {
    projectItems.forEach(item => {
      const itemCategory = item.getAttribute('data-category');
      if (filterValue === 'all' || itemCategory === filterValue) {
        (item as HTMLElement).style.display = 'block';
        setTimeout(() => {
          item.classList.remove('fade-out');
        }, 50);
      } else {
        item.classList.add('fade-out');
        setTimeout(() => {
          if (item.classList.contains('fade-out')) {
            (item as HTMLElement).style.display = 'none';
          }
        }, 400);
      }
    });
  };

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      filterButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filterValue = btn.getAttribute('data-filter') || 'all';
      applyFilter(filterValue);
    });
  });

  window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const filterParam = params.get('filter');
    if (filterParam) {
      const targetBtn = document.querySelector(`.filter-btn[data-filter="${filterParam}"]`);
      if (targetBtn) {
        (targetBtn as HTMLElement).click();
      }
    }
  });
</script>

<style>
  .portfolio-page {
    background-color: var(--color-sand-light);
    padding-top: 5rem;
  }

  .portfolio-header {
    margin-bottom: 4rem;
    max-width: 800px;
  }

  .section-tag {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-olive);
    display: block;
    margin-bottom: 1rem;
  }

  .portfolio-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--color-charcoal);
    margin-bottom: 1.5rem;
  }

  .portfolio-subtitle {
    font-size: 1.25rem;
    color: var(--color-charcoal-light);
    line-height: 1.7;
    font-weight: 300;
  }

  .portfolio-filter {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
    margin-bottom: 5rem;
    border-bottom: 1px solid var(--color-sand-dark);
    padding-bottom: 2rem;
  }

  .filter-btn {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-charcoal-light);
    background: none;
    border: none;
    padding: 0.5rem 0 1.95rem 0;
    cursor: pointer;
    position: relative;
    transition: var(--transition-fast);
    font-weight: 500;
  }

  .filter-btn::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-charcoal);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .filter-btn:hover {
    color: var(--color-charcoal);
  }

  .filter-btn.active {
    color: var(--color-charcoal);
  }

  .filter-btn.active::after {
    transform: scaleX(1);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 5rem 4rem;
  }

  .project-item-wrapper {
    opacity: 1;
    transform: scale(1);
    transition: opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1), transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .project-item-wrapper.fade-out {
    opacity: 0;
    transform: scale(0.96);
  }

  .project-featured {
    grid-column: 1 / -1;
  }

  @media (max-width: 992px) {
    .portfolio-filter {
      gap: 1rem 2rem;
    }
  }

  @media (max-width: 768px) {
    .portfolio-page {
      padding-top: 4rem;
    }

    .portfolio-header {
      margin-bottom: 3rem;
    }

    .portfolio-filter {
      justify-content: flex-start;
      gap: 1rem 1.5rem;
      padding-bottom: 1.5rem;
    }

    .filter-btn {
      padding-bottom: 1.45rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .project-featured {
      grid-column: auto;
    }
  }
</style>
