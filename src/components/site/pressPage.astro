---

<Layout
  title={`S'Estepa Design | ${t('press.title')}`}
  description={pageDescription}
  lang={lang}
  image="/portfolio/crestatx-garden-design/garden-design-mallorca-crestatx-garden-design-sestepa.webp"
>
  <!-- Subpage Header -->
  <section class="subpage-header">
    <div class="container header-grid">
      <div class="header-text">
        <span class="header-tag">{t('nav.press')}</span>
        <h1 class="header-title">{pressH1[lang]}</h1>
        <p class="header-subtitle">{pageSubtitle[lang]}</p>
      </div>
      <div class="header-image-container">
        <img src="/portfolio/crestatx-garden-design/garden-design-mallorca-crestatx-garden-design-sestepa.webp" alt="S'Estepa Design Press Background" class="header-image" />
      </div>
    </div>
  </section>

  <!-- Editorial Section -->
  <section class="press-section section-padding">
    <div class="container">

      <div class="press-list">
        {publications.map((pub, index) => (
          <div class="press-row">
            <!-- Meta Column -->
            <div class="press-meta-card">
              <span class="pub-magazine">{pub.magazine}</span>
              <h3 class="pub-title">{pub.title[lang]}</h3>
              <span class="pub-date">{pub.date[lang]}</span>
              <p class="pub-excerpt">{pub.excerpt[lang]}</p>
              
              <a 
                href={pub.link} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="pub-btn"
              >
                {pub.linkType === 'external' ? readMoreText[lang] : downloadText[lang]} &rarr;
              </a>
            </div>

            <!-- Gallery Column -->
            <div class="press-gallery">
              {pub.images.map((img, imgIdx) => (
                <button 
                  class="press-img-btn" 
                  data-src={img} 
                  data-title={pub.title[lang]}
                  data-index={`${index}-${imgIdx}`}
                  aria-label={`View full resolution press layout for ${pub.title[lang]}`}
                >
                  <img src={img} alt={`${pub.title[lang]} page spread`} class="press-thumb" />
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog">
    <div class="lightbox-overlay" id="lightbox-overlay"></div>
    <div class="lightbox-content">
      <button class="lightbox-close" id="lightbox-close" aria-label="Close image">&times;</button>
      <button class="lightbox-arrow lightbox-prev" id="lightboxPrev" aria-label="Previous image">&larr;</button>
      <img src="" alt="" class="lightbox-img" id="lightbox-img" />
      <button class="lightbox-arrow lightbox-next" id="lightboxNext" aria-label="Next image">&rarr;</button>
      <span class="lightbox-caption" id="lightbox-caption"></span>
    </div>
  </div>
</Layout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": publications.map((pub, i) => ({
    "@type": "NewsArticle",
    "headline": pub.title['en'],
    "name": pub.title[lang],
    "description": pub.excerpt[lang],
    "datePublished": publicationDates[i],
    "publisher": {
      "@type": "Organization",
      "name": pub.magazine,
      "sameAs": pub.magazine === "abcMallorca"
        ? "https://www.abc-mallorca.com"
        : "https://www.spendinmagazine.com"
    },
    "about": {
      "@type": "LocalBusiness",
      "@id": "https://design.sestepa.com/#business",
      "name": "S'Estepa Design",
      "description": "Garden design and landscape architecture studio in Mallorca, specialising in Mediterranean gardens for fincas and villas.",
      "url": "https://design.sestepa.com"
    },
    "url": pub.link,
    "image": pub.images[0]
      ? `https://design.sestepa.com${pub.images[0]}`
      : undefined
  }))
})} />

<script>
  const buttons = document.querySelectorAll('.press-img-btn') as NodeListOf<HTMLButtonElement>;
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxOverlay = document.getElementById('lightbox-overlay');
  const lightboxPrev = document.getElementById('lightboxPrev');
  const lightboxNext = document.getElementById('lightboxNext');

  if (lightbox && lightboxImg && lightboxCaption && lightboxClose && lightboxOverlay && lightboxPrev && lightboxNext) {
    let currentPubIndex = -1;
    let currentImgIndex = -1;
    const pubImages: { [key: number]: { src: string; title: string }[] } = {};

    buttons.forEach((btn) => {
      const idxStr = btn.getAttribute('data-index') || '';
      const [pubIdx, imgIdx] = idxStr.split('-').map(Number);
      const src = btn.getAttribute('data-src') || '';
      const title = btn.getAttribute('data-title') || '';

      if (!pubImages[pubIdx]) {
        pubImages[pubIdx] = [];
      }
      pubImages[pubIdx][imgIdx] = { src, title };
    });

    const openLightbox = (pubIdx: number, imgIdx: number) => {
      currentPubIndex = pubIdx;
      currentImgIndex = imgIdx;
      updateLightbox();
      lightbox.classList.add('active');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      lightbox.classList.remove('active');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lightboxImg.src = '';
    };

    const updateLightbox = () => {
      const images = pubImages[currentPubIndex];
      if (images && images[currentImgIndex]) {
        const item = images[currentImgIndex];
        lightboxImg.src = item.src;
        lightboxImg.alt = item.title;
        lightboxCaption.textContent = `${item.title} (${currentImgIndex + 1} / ${images.length})`;
      }
    };

    const showPrev = () => {
      const images = pubImages[currentPubIndex];
      if (images) {
        currentImgIndex = (currentImgIndex - 1 + images.length) % images.length;
        updateLightbox();
      }
    };

    const showNext = () => {
      const images = pubImages[currentPubIndex];
      if (images) {
        currentImgIndex = (currentImgIndex + 1) % images.length;
        updateLightbox();
      }
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const idxStr = btn.getAttribute('data-index') || '';
        const [pubIdx, imgIdx] = idxStr.split('-').map(Number);
        openLightbox(pubIdx, imgIdx);
      });
    });

    lightboxClose.addEventListener('click', closeLightbox);
    lightboxOverlay.addEventListener('click', closeLightbox);
    
    lightboxPrev.addEventListener('click', (e) => {
      e.stopPropagation();
      showPrev();
    });
    
    lightboxNext.addEventListener('click', (e) => {
      e.stopPropagation();
      showNext();
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('active')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') showPrev();
        if (e.key === 'ArrowRight') showNext();
      }
    });

    // Swipe controls for touch screens
    let touchStartX = 0;
    let touchEndX = 0;

    lightbox.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    lightbox.addEventListener('touchend', (e: TouchEvent) => {
      touchEndX = e.changedTouches[0].screenX;
      const swipeThreshold = 50;
      if (touchEndX < touchStartX - swipeThreshold) {
        showNext();
      }
      if (touchEndX > touchStartX + swipeThreshold) {
        showPrev();
      }
    }, { passive: true });
  }
</script>

<style>
  /* Subpage Header */
  .subpage-header {
    background-color: var(--color-sand-light);
    padding: 9rem 0 6rem 0;
    border-bottom: 1px solid var(--color-sand-dark);
  }

  .header-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .header-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .header-tag {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-olive);
  }

  .header-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--color-charcoal);
  }

  .header-subtitle {
    font-size: 1.25rem;
    color: var(--color-charcoal-light);
    line-height: 1.6;
    font-weight: 300;
  }

  .header-image-container {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--color-sand-base);
    border: 1px solid var(--color-sand-dark);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.03);
  }

  .header-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .header-image-container:hover .header-image {
    transform: scale(1.03);
  }

  @media (max-width: 992px) {
    .subpage-header {
      padding: 7.5rem 0 4rem 0;
    }

    .header-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .header-image-container {
      aspect-ratio: 16 / 9;
      max-height: 350px;
    }
  }

  /* Editorial Section */
  .press-section {
    background-color: var(--color-white);
  }

  .press-list {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  .press-row {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 4rem;
    align-items: start;
    border-bottom: 1px solid rgba(227, 221, 211, 0.4);
    padding-bottom: 6rem;
  }

  .press-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .press-meta-card {
    background-color: var(--color-sand-light);
    border: 1px solid rgba(227, 221, 211, 0.4);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: var(--transition-medium);
  }

  .press-meta-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
  }

  .pub-magazine {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-olive);
    text-transform: uppercase;
  }

  .pub-title {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--color-charcoal);
    line-height: 1.2;
  }

  .pub-date {
    font-size: 0.85rem;
    color: var(--color-limestone);
    margin-bottom: 0.5rem;
  }

  .pub-excerpt {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-charcoal-light);
    margin-bottom: 1.5rem;
  }

  .pub-btn {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-white);
    background-color: var(--color-olive);
    padding: 0.75rem 1.5rem;
    transition: var(--transition-fast);
  }

  .pub-btn:hover {
    background-color: var(--color-olive-dark);
  }

  /* Gallery Column */
  .press-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .press-img-btn {
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-sand-base);
    border: 1px solid rgba(227, 221, 211, 0.4);
    cursor: pointer;
    padding: 0;
    transition: var(--transition-medium);
  }

  .press-img-btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border-color: var(--color-olive);
  }

  .press-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .press-img-btn:hover .press-thumb {
    transform: scale(1.05);
  }

  /* Lightbox Modal */
  .lightbox {
    position: fixed;
