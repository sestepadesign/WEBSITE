---
import ProjectDetail from '../components/ProjectDetail.astro';
import { projects } from '../data/projects';
import { getProjectStaticPathParams } from '../lib/urls';
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const projectPaths = getProjectStaticPathParams('en').map(({ params, props }) => {
    const project = projects.find((p) => p.slug === props.projectSlug)!;
    return {
      params,
      props: {
        kind: 'project' as const,
        project,
        canonicalPath: props.canonicalPath,
      },
    };
  });

  const posts = await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft);
  const blogPaths = posts.map((post) => {
    const slug = post.id.replace(/\.md$/, '').split('/').pop()!;
    return {
      params: { slug },
      props: { kind: 'blog' as const, post },
    };
  });

  return [...projectPaths, ...blogPaths];
}

const props = Astro.props;
let BlogContent: Awaited<ReturnType<typeof render>>['Content'] | null = null;

if (props.kind === 'blog') {
  const rendered = await render(props.post);
  BlogContent = rendered.Content;
}

const wordCount = props.kind === 'blog' ? props.post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

{props.kind === 'project' ? (
  <ProjectDetail
    project={props.project}
    lang="en"
    canonicalPath={props.canonicalPath}
  />
) : (
  <Layout
    title={props.post.data.title.replace(/&#038;/g, '&').replace(/&#8217;/g, "'") + " | S'Estepa Design"}
    description={props.post.data.description}
    lang="en"
    image={props.post.data.image ?? '/portfolio/finca-garden-campos-mallorca/cover.webp'}
    hreflangLocales={['en']}
    noindex={props.post.data.noindex}
  >
    <section class="blog-hero">
      <div class="video-container" aria-hidden="true">
        <video autoplay loop muted playsinline aria-label="Decorative background video">
          <source src="/videos/hero-bg.mp4" type="video/mp4" />
        </video>
        <div class="overlay"></div>
      </div>
      <div class="hero-content">
        <h1 set:html={props.post.data.title} />
        {props.kind === 'blog' && (
          <span class="ux-meta">
            S'ESTEPA STUDIO &nbsp;&middot;&nbsp; {readingTime} MIN READ
          </span>
        )}
      </div>
    </section>

    <article class="container section-padding blog-post" id="blog-content">
      <div class="blog-content" set:html={BlogContent ? '' : ''}>
        {BlogContent && <BlogContent />}
      </div>
    </article>
  </Layout>
)}

<style is:global>
  .blog-hero {
    position: relative;
    height: 70vh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    overflow: hidden;
  }
  .video-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }
  .video-container video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    padding: 2rem;
  }
  .hero-content h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    font-weight: 400;
  }
  .hero-content .ux-meta {
    font-family: 'Jost', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
    opacity: 0.9;
    display: inline-block;
    border-top: 1px solid rgba(255, 255, 255, 0.3);
    padding-top: 1rem;
    margin-top: 0.5rem;
  }
  .blog-post.section-padding {
    padding: 6rem 2rem;
    display: flex;
    justify-content: center;
  }
  .blog-content {
    width: 100%;
    max-width: 800px;
    line-height: 1.8;
    font-family: 'Jost', sans-serif;
    font-size: 1.1rem;
    color: var(--text-color, #333);
  }
  .blog-content h2, .blog-content h3 {
    font-family: 'Cormorant Garamond', serif;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    font-weight: 400;
  }
  .blog-content h2 {
    font-size: 2.2rem;
  }
  .blog-content h3 {
    font-size: 1.8rem;
  }
  .blog-content p {
    margin-bottom: 1.5rem;
  }
</style>
