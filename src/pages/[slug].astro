---
import ProjectDetail from '../components/ProjectDetail.astro';
import { projects } from '../data/projects';
import { getProjectStaticPathParams } from '../lib/urls';
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const projectPaths = getProjectStaticPathParams('en').map(({ params, props }) => {
    const project = projects.find((p) => p.slug === props.projectSlug)!;
    return {
      params,
      props: {
        kind: 'project' as const,
        project,
        canonicalPath: props.canonicalPath,
      },
    };
  });

  const posts = await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft);
  const blogPaths = posts.map((post) => {
    const slug = post.id.replace(/\.md$/, '').split('/').pop()!;
    return {
      params: { slug },
      props: { kind: 'blog' as const, post },
    };
  });

  return [...projectPaths, ...blogPaths];
}

const props = Astro.props;
let BlogContent: Awaited<ReturnType<typeof render>>['Content'] | null = null;

if (props.kind === 'blog') {
  const rendered = await render(props.post);
  BlogContent = rendered.Content;
}

const wordCount = props.kind === 'blog' ? props.post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

{props.kind === 'project' ? (
  <ProjectDetail
    project={props.project}
    lang="en"
    canonicalPath={props.canonicalPath}
  />
) : (
  <Layout
    title={props.post.data.title.replace(/&#038;/g, '&').replace(/&#8217;/g, "'") + " | S'Estepa Design"}
    description={props.post.data.description}
    lang="en"
    image={props.post.data.image ?? '/portfolio/finca-garden-campos-mallorca/cover.webp'}
    hreflangLocales={['en']}
    noindex={props.post.data.noindex}
  >
    <section class="blog-hero">
      <div class="video-container" aria-hidden="true">
        <video autoplay loop muted playsinline aria-label="Decorative background video">
          <source src="/videos/hero-bg.mp4" type="video/mp4" />
        </video>
        <div class="overlay"></div>
      </div>
      <div class="hero-content">
        <h1 set:html={props.post.data.title} />
        {props.kind === 'blog' && (
          <span class="ux-meta">
            S'ESTEPA STUDIO &nbsp;&middot;&nbsp; {readingTime} MIN READ
          </span>
        )}
      </div>
    </section>

    <article class="container section-padding blog-post" id="blog-content">
      <div class="blog-content" set:html={BlogContent ? '' : ''}>
        {BlogContent && <BlogContent />}
      </div>
    </article>
  </Layout>
)}

