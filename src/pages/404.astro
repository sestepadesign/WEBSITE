---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | S'Estepa Design"
  description="This page no longer exists, but S'Estepa Design's Mediterranean gardens are just a click away."
  lang="en"
  canonicalPath="/404/"
  hreflangLocales={['en']}
  noindex={true}
>
  <section class="not-found container section-padding">
    <img
      src="/images/S-ESTEPA-GARDEN-DESIGN-MALLORCA-LOGO-BLACK-344.webp"
      alt="S'Estepa Design"
      class="not-found-logo"
      width="220"
      height="31"
    />

    <span class="not-found-eyebrow">404</span>
    <h1 class="not-found-title">This path has grown <em>wild</em></h1>
    <p class="not-found-copy">
      The page you're looking for may have moved, or perhaps it never bloomed at all.
      Search the site, or let us guide you back to solid ground.
    </p>

    <div id="search" class="not-found-search"></div>

    <nav class="not-found-links" aria-label="Suggested pages">
      <a href="/portfolio/" class="not-found-btn">Explore the Portfolio <span class="arrow">&rarr;</span></a>
      <a href="/gallery/" class="not-found-btn">View the Gallery <span class="arrow">&rarr;</span></a>
      <a href="/contact/" class="not-found-btn not-found-btn-primary">Contact Us <span class="arrow">&rarr;</span></a>
    </nav>

    <a href="/" class="not-found-home">&larr; Back to the homepage</a>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        new PagefindUI({ element: '#search', showSubResults: true, showImages: false });
      }
    });
  </script>
</Layout>

<style>
  .not-found {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 10rem;
    padding-bottom: 6rem;
  }

  .not-found-logo {
    width: 180px;
    height: auto;
    margin-bottom: 2.5rem;
    opacity: 0.85;
  }

  .not-found-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    color: var(--color-olive);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .not-found-title {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 400;
    color: var(--color-charcoal);
    margin-bottom: 1.25rem;
    line-height: 1.15;
  }

  .not-found-title em {
    font-style: italic;
    color: var(--color-olive-dark);
  }

  .not-found-copy {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    color: var(--color-limestone);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 2.75rem;
  }

  .not-found-search {
    width: 100%;
    max-width: 480px;
    margin-bottom: 2.5rem;
    --pagefind-ui-primary: var(--color-olive);
    --pagefind-ui-text: var(--color-charcoal);
    --pagefind-ui-background: var(--color-white);
    --pagefind-ui-border: var(--color-sand-dark);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-font: var(--font-sans);
  }

  .not-found-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .not-found-btn {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-charcoal);
    border: 1px solid var(--color-sand-dark);
    padding: 1rem 1.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    transition: var(--transition-fast);
    background: var(--color-white);
  }

  .not-found-btn:hover {
    border-color: var(--color-olive);
    color: var(--color-olive);
  }

  .not-found-btn-primary {
    background: var(--color-olive);
    border-color: var(--color-olive);
    color: var(--color-white);
  }

  .not-found-btn-primary:hover {
    background: var(--color-olive-dark);
    border-color: var(--color-olive-dark);
    color: var(--color-white);
  }

  .not-found-btn .arrow {
    transition: transform 0.3s ease;
  }

  .not-found-btn:hover .arrow {
    transform: translateX(4px);
  }

  .not-found-home {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-limestone);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .not-found-home:hover {
    color: var(--color-olive);
  }
</style>
