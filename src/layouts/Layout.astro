---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';
import {
  SITE_NAME,
  SITE_LOCALES,
  getHreflangAlternates,
  type SiteLocale,
  GTM_ID,
  GTAG_ID,
  GOOGLE_ADS_ID,
  GA4_ID,
  COOKIEYES_CLIENT_ID
} from '../lib/seo';
import { PAGE_OG_IMAGES } from '../data/site-urls';
import { resolvePageIdFromPath } from '../lib/urls';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'es' | 'de';
  /** Path to OG image, e.g. /portfolio/sant-llorenc/images/garden-design-mallorca-sant-llorenc-sestepa.webp */
  image?: string;
  /** Override canonical path (aliases, homepage). */
  canonicalPath?: string;
  /** If set, adds meta refresh after full OG head (legacy). */
  redirectTo?: string;
  /** Locales with a real alternate page (default: all). Blog posts EN-only use ['en']. */
  hreflangLocales?: SiteLocale[];
  /** Hidden pages (SEO archive) â€” noindex, not linked in nav */
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  image = '/portfolio/sant-llorenc/images/garden-design-mallorca-sant-llorenc-sestepa.webp',
  canonicalPath: canonicalPathProp,
  redirectTo,
  hreflangLocales = SITE_LOCALES,
  noindex = false,
} = Astro.props;

const site = Astro.site!;
const canonicalPath = canonicalPathProp ?? redirectTo ?? Astro.url.pathname;
const canonicalURL = new URL(canonicalPath, site);

const pageId = resolvePageIdFromPath(canonicalPath);
const defaultOgImage = pageId ? PAGE_OG_IMAGES[pageId]?.[lang] : undefined;
const resolvedImage = image !== '/portfolio/sant-llorenc/images/garden-design-mallorca-sant-llorenc-sestepa.webp' ? image : (defaultOgImage ?? image);
const ogImage = new URL(resolvedImage, site);

const ogLocales: Record<typeof lang, string> = {
  en: 'en_US',
  es: 'es_ES',
  de: 'de_DE',
};

const hreflangLinks = redirectTo ? [] : getHreflangAlternates(canonicalPath, site, hreflangLocales);
const ogLocaleAlternates = SITE_LOCALES.filter((l) => l !== lang).map((l) => ogLocales[l]);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <!-- Start cookieyes banner -->
    <script id="cookieyes" src={`https://cdn-cookieyes.com/client_data/${COOKIEYES_CLIENT_ID}/script.js`}></script>
    <!-- End cookieyes banner -->
    <!-- Google Tag Manager -->
    <script define:vars={{ GTM_ID }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',GTM_ID);
    </script>
    <!-- End Google Tag Manager -->
    <!-- Google tag (gtag.js) -->
    <script src={`https://www.googletagmanager.com/gtag/js?id=${GTAG_ID}`}></script>
    <script define:vars={{ GTAG_ID, GOOGLE_ADS_ID, GA4_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GTAG_ID);
      gtag('config', GOOGLE_ADS_ID);
      gtag('config', GA4_ID);
    </script>

    <link rel="preload" as="font" href="/fonts/jost-400.woff2" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" as="font" href="/fonts/cormorant-garamond-400.woff2" type="font/woff2" crossorigin="anonymous" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon-192x192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/favicon-192x192.png" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    {hreflangLinks.map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="S'Estepa Design" />
    <meta property="og:locale" content={ogLocales[lang]} />
    {ogLocaleAlternates.map((locale) => (
      <meta property="og:locale:alternate" content={locale} />
    ))}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {image.endsWith('.jpg') || image.endsWith('.jpeg') ? (
      <meta property="og:image:type" content="image/jpeg" />
    ) : image.endsWith('.webp') ? (
      <meta property="og:image:type" content="image/webp" />
    ) : null}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@sestepadesign" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {redirectTo && <meta http-equiv="refresh" content={`0;url=${redirectTo}`} />}

    <link rel="preload" as="image" href="/images/S-ESTEPA-GARDEN-DESIGN-MALLORCA-LOGO-BLACK-344.webp" fetchpriority="high" />

    {!noindex && <Schema canonicalPath={canonicalPath} />}

    {(canonicalPath === '/' || canonicalPath === '' || canonicalPath === '/es' || canonicalPath === '/de') && (
      <link rel="preload" as="image" href="/videos/sant_llorenc_poster.webp" fetchpriority="high" />
    )}
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    {redirectTo ? (
      <p style="display:none">Redirecting to <a href={redirectTo}>{redirectTo}</a></p>
    ) : (
      <div class="site-wrapper">
        <Header lang={lang} />
        <main id="main-content">
          <slot />
        </main>
        <Footer lang={lang} />
      </div>
    )}
    {!redirectTo && (
      <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
          document.body.addEventListener('click', (e) => {
            const anchor = e.target.closest('a');
            if (anchor && anchor.href && anchor.href.includes('wa.me')) {
              const pathname = window.location.pathname;
              const actionUrl = "https://script.google.com/macros/s/AKfycbzR8Kdmb5xfZv1___-qDOmeWgYuSOfwWlqQb00_6x37EACe4xKpgnlU5ZHRJuCPoZIszQ/exec";
              const params = new URLSearchParams({
                name: "WhatsApp Click",
                email: "---",
                subject: "WhatsApp",
                message: `Click en el botón de WhatsApp desde: ${pathname}`,
                token: "sestepa_secure_2026"
              });
              fetch(`${actionUrl}?${params.toString()}`, { 
                method: "GET", 
                mode: "no-cors",
                keepalive: true
              }).catch(err => console.error("WhatsApp click logging failed:", err));
            }
          });
        });
      </script>
    )}
  </body>
</html>

<style>
  .site-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    background-color: var(--color-sand-light);
  }

  main {
    flex-grow: 1;
  }
</style>



